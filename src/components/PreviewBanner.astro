---
import type { Locale } from "../i18n/locales";
import { getUiMessages } from "../i18n/load-locale";
import { t } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const ui = getUiMessages(locale);
---

<button
  type="button"
  class="preview-banner"
  data-preview-open
  aria-haspopup="dialog"
  aria-controls="preview-disclaimer"
>
  {t(locale, ui, "layout.preview")}
</button>

<div
  id="preview-disclaimer"
  class="preview-modal"
  data-preview-modal
  data-open="false"
  aria-hidden="true"
>
  <button
    type="button"
    class="preview-modal__backdrop"
    data-preview-close
    aria-label={t(locale, ui, "layout.previewCloseAria")}
  ></button>
  <section
    class="preview-modal__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="preview-disclaimer-title"
    tabindex="-1"
    data-preview-panel
  >
    <button
      type="button"
      class="preview-modal__close"
      data-preview-close
      aria-label={t(locale, ui, "layout.previewCloseAria")}
    >
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
        <path d="M18.3 5.71 12 12.01l-6.3-6.3-1.41 1.41L10.59 13.4l-6.3 6.3 1.41 1.41 6.3-6.3 6.3 6.3 1.41-1.41-6.3-6.3 6.3-6.3z"></path>
      </svg>
    </button>
    <div class="preview-modal__content">
      <p class="preview-modal__eyebrow">{t(locale, ui, "layout.previewBuild")}</p>
      <h2 id="preview-disclaimer-title">{t(locale, ui, "layout.previewDisclaimer")}</h2>
      <p>{t(locale, ui, "layout.previewBody1")}</p>
      <p>{t(locale, ui, "layout.previewBody2")}</p>
    </div>
  </section>
</div>

<script>
  import { lockPageScroll, unlockPageScroll } from "../scripts/scroll-lock.ts";

  const modal = document.querySelector<HTMLElement>("[data-preview-modal]");
  const panel = document.querySelector<HTMLElement>("[data-preview-panel]");
  const openButton = document.querySelector<HTMLButtonElement>("[data-preview-open]");
  const closeButtons = document.querySelectorAll<HTMLButtonElement>("[data-preview-close]");

  function setPreviewModalOpen(open: boolean) {
    if (!modal) return;
    modal.setAttribute("data-open", open ? "true" : "false");
    modal.setAttribute("aria-hidden", open ? "false" : "true");
    if (open) {
      lockPageScroll();
      panel?.focus({ preventScroll: true });
    } else {
      unlockPageScroll();
      openButton?.focus({ preventScroll: true });
    }
  }

  openButton?.addEventListener("click", () => setPreviewModalOpen(true));

  closeButtons.forEach((button) => {
    button.addEventListener("click", () => setPreviewModalOpen(false));
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") return;
    if (modal?.getAttribute("data-open") !== "true") return;
    event.preventDefault();
    setPreviewModalOpen(false);
  });
</script>
