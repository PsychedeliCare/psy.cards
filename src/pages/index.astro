---
import Layout from "../components/Layout.astro";
import Footer from "../components/Footer.astro";

export const prerender = true;
---

<Layout
  title="psy.cards"
  description="A multilingual harm reduction card project that turns verified knowledge bases into compact, readable guidance."
>
  <main class="landing">
    <section class="hero">
      <p class="eyebrow">psy.cards</p>
      <h1>Harm reduction, compact and legible.</h1>
      <p class="lede">
        A multilingual project that turns verified knowledge bases into
        compact, readable guidance across print, web, and social media.
      </p>
      <p class="cta">
        <a href="/combos" class="primary">Explore drug combinations</a>
      </p>
    </section>

    <section class="about">
      <p>
        The goal is to make high-quality substance information easier to
        access, translate, and distribute responsibly. Each format respects
        strong space constraints so the most important information surfaces
        first: on a printed card, in a carousel post, or behind a QR code on
        the web.
      </p>
    </section>

  </main>

  <Footer variant="narrow" />
</Layout>

<style>
  .landing {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 20px 80px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .hero {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .eyebrow {
    margin: 0;
    font-size: 12px;
    color: var(--color-fg-mute);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    max-width: 14ch;
  }

  .lede {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-fg);
    max-width: 52ch;
  }

  .cta {
    margin: 6px 0 0;
  }

  .primary {
    display: inline-block;
    padding: 10px 18px;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.01em;
    color: var(--color-ink);
    background-color: var(--color-safe);
    text-decoration: none;
    transition:
      filter 140ms ease,
      transform 140ms ease;
  }

  .primary:hover {
    filter: brightness(1.1);
  }

  .about p {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--color-fg);
    max-width: 58ch;
  }
</style>
