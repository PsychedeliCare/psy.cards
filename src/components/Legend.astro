---
import Icon from "./Icon.astro";
import { legendDefinitions } from "../data/definitions";
---

<aside class="legend" aria-label="Legend">
  <ul>
    {
      legendDefinitions.map((def) => (
        <li class={`status-${def.statusKey}`}>
          <span class="chip status-icon-chip status-surface">
            <Icon name={def.icon} size="1.05em" />
          </span>
          <span class="body">
            <span class="label">{def.label}</span>
            <span class="definition">{def.definition}</span>
          </span>
        </li>
      ))
    }
  </ul>
</aside>

<style>
  .legend {
    width: 100%;
    padding: 18px 16px 6px;
  }

  .legend ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px 18px;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  }

  .legend li {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 12px;
    line-height: 1.45;
    color: var(--color-fg);
  }

  .chip {
    --status-icon-chip-size: 30px;
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .label {
    font-weight: 600;
    color: var(--color-fg);
  }

  .definition {
    color: var(--color-fg-mute);
    font-size: 11.5px;
  }
</style>
