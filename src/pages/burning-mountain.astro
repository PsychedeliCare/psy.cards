---
import Layout from "../components/Layout.astro";
import ComboTable from "../components/ComboTable.astro";
import Legend from "../components/Legend.astro";
import Footer from "../components/Footer.astro";

export const prerender = true;

const localizedContent = {
  en: {
    eyebrow: "Burning Mountain Festival · Zernez",
    title: "ALPS Psycare",
    intro:
      "ALPS PsyCare brings science-based psychedelic education and non-judgmental psychological support into Swiss festival settings. By combining evidence-informed harm reduction, community care, and compassionate on-site support, the initiative helps people seek help early and prevents small difficulties from becoming serious incidents.",
    mapLabel: "Festival map",
    mapTitle: "Burning Mountain site map",
    mapText:
      "Use the festival map to orient yourself on site. Check the latest signage and ask the info point, medical team, security, or PsyCare if you need help finding support.",
    resourcesEyebrow: "Festival support",
    resourcesTitle: "Useful resources in the moment",
    chartEyebrow: "Combination reference",
    chartTitle: "Drug combinations chart",
    chartText:
      "Use this common festival-substance chart as a quick reference, then speak with PsyCare, medical staff, or another trusted support person if something feels off.",
  },
  de: {
    eyebrow: "Burning Mountain Festival · Zernez",
    title: "ALPS Psycare",
    intro:
      "ALPS PsyCare bringt wissenschaftsbasierte psychedelische Bildung und nicht-wertende psychologische Unterstuetzung in Schweizer Festivalumgebungen. Durch evidenzinformierte Schadensminderung, Gemeinschaftsfuerorge und mitfuehlende Hilfe vor Ort ermutigt die Initiative Menschen, frueh Unterstuetzung zu suchen, bevor kleine Schwierigkeiten zu ernsten Vorfaellen werden.",
    mapLabel: "Festivalplan",
    mapTitle: "Burning-Mountain-Gelaendeplan",
    mapText:
      "Nutze den Festivalplan zur Orientierung vor Ort. Achte auf die aktuelle Beschilderung und frage Infopunkt, Sanitaet, Security oder PsyCare, wenn du Unterstuetzung suchst.",
    resourcesEyebrow: "Festival-Support",
    resourcesTitle: "Nuetzliche Hilfe im Moment",
    chartEyebrow: "Kombinationsreferenz",
    chartTitle: "Drug combinations chart",
    chartText:
      "Nutze diese Tabelle mit haeufigen Festival-Substanzen als schnelle Orientierung und sprich mit PsyCare, Sanitaet oder einer vertrauten Person, wenn sich etwas falsch anfuehlt.",
  },
  fr: {
    eyebrow: "Burning Mountain Festival · Zernez",
    title: "ALPS Psycare",
    intro:
      "ALPS PsyCare apporte une education psychedelique fondee sur la science et un soutien psychologique sans jugement dans les festivals suisses. En combinant reduction des risques, soin communautaire et accompagnement bienveillant sur place, l'initiative aide les personnes a demander du soutien tot, avant que de petites difficultes ne deviennent des incidents graves.",
    mapLabel: "Plan du festival",
    mapTitle: "Plan du site Burning Mountain",
    mapText:
      "Utilise le plan du festival pour t'orienter sur place. Verifie la signaletique actuelle et demande au point info, a l'equipe medicale, a la securite ou a PsyCare si tu cherches du soutien.",
    resourcesEyebrow: "Soutien festival",
    resourcesTitle: "Ressources utiles sur le moment",
    chartEyebrow: "Reference des combinaisons",
    chartTitle: "Drug combinations chart",
    chartText:
      "Utilise ce tableau des substances frequentes en festival comme reference rapide, puis parle a PsyCare, a l'equipe medicale ou a une personne de confiance si quelque chose ne va pas.",
  },
  it: {
    eyebrow: "Burning Mountain Festival · Zernez",
    title: "ALPS Psycare",
    intro:
      "ALPS PsyCare porta nei festival svizzeri educazione psichedelica basata sulla scienza e supporto psicologico non giudicante. Unendo riduzione del danno, cura della comunita e presenza compassionevole sul posto, l'iniziativa aiuta le persone a chiedere sostegno presto, prima che piccole difficolta diventino incidenti seri.",
    mapLabel: "Mappa del festival",
    mapTitle: "Mappa dell'area Burning Mountain",
    mapText:
      "Usa la mappa del festival per orientarti sul posto. Controlla la segnaletica aggiornata e chiedi al punto informazioni, al team medico, alla sicurezza o a PsyCare se cerchi supporto.",
    resourcesEyebrow: "Supporto festival",
    resourcesTitle: "Risorse utili nel momento",
    chartEyebrow: "Riferimento combinazioni",
    chartTitle: "Drug combinations chart",
    chartText:
      "Usa questa tabella delle sostanze comuni nei festival come riferimento rapido, poi parla con PsyCare, con il team medico o con una persona fidata se qualcosa non va.",
  },
} as const;

const resources = [
  {
    key: "emergency",
    iconPath:
      "M12 2.25 3.25 6.1v5.9c0 5.05 3.5 8.22 8.75 9.75 5.25-1.53 8.75-4.7 8.75-9.75V6.1L12 2.25Zm1 5.75v3h3v2h-3v3h-2v-3H8v-2h3V8h2Z",
    label: "Emergency",
    title: "Need urgent medical help?",
    text: "Go to the nearest medical, security, or PsyCare team member. For life-threatening situations in Switzerland call ambulance 144 or European emergency 112.",
    href: "tel:144",
    action: "Call 144",
    translations: {
      de: {
        label: "Notfall",
        title: "Brauchst du dringend medizinische Hilfe?",
        text: "Geh zum naechsten Sanitaets-, Sicherheits- oder PsyCare-Teammitglied. Bei lebensbedrohlichen Situationen in der Schweiz rufe die Ambulanz 144 oder den europaeischen Notruf 112.",
        action: "144 anrufen",
      },
      fr: {
        label: "Urgence",
        title: "Besoin d'une aide medicale urgente ?",
        text: "Adresse-toi a l'equipe medicale, a la securite ou a PsyCare la plus proche. En cas de danger vital en Suisse, appelle l'ambulance au 144 ou le numero europeen 112.",
        action: "Appeler 144",
      },
      it: {
        label: "Emergenza",
        title: "Hai bisogno di aiuto medico urgente?",
        text: "Vai dal team medico, di sicurezza o PsyCare piu vicino. In situazioni di pericolo di vita in Svizzera chiama l'ambulanza al 144 o il numero europeo 112.",
        action: "Chiama 144",
      },
    },
  },
  {
    key: "festival",
    iconPath:
      "M4 4h16v12H5.5L4 18.5V4Zm3 3v2h10V7H7Zm0 4v2h7v-2H7Zm-1 10h12v-2H6v2Z",
    label: "Festival",
    title: "Burning Mountain information",
    text: "Official updates, tickets, venue details, camping, facilities, and travel information for the festival in Zernez.",
    href: "https://www.burning-mountain.ch/",
    action: "Open festival site",
    translations: {
      de: {
        label: "Festival",
        title: "Burning-Mountain-Informationen",
        text: "Offizielle Updates, Tickets, Details zum Gelaende, Camping, Infrastruktur und Anreiseinformationen fuer das Festival in Zernez.",
        action: "Festival-Website oeffnen",
      },
      fr: {
        label: "Festival",
        title: "Informations Burning Mountain",
        text: "Actualites officielles, billets, details du site, camping, infrastructures et informations de voyage pour le festival a Zernez.",
        action: "Ouvrir le site du festival",
      },
      it: {
        label: "Festival",
        title: "Informazioni Burning Mountain",
        text: "Aggiornamenti ufficiali, biglietti, dettagli dell'area, campeggio, servizi e informazioni di viaggio per il festival a Zernez.",
        action: "Apri il sito del festival",
      },
    },
  },
  {
    key: "safer-use",
    iconPath:
      "M9 3h6v2l-1.5 1.5v3.15l4.88 7.82A2.3 2.3 0 0 1 16.42 21H7.58a2.3 2.3 0 0 1-1.96-3.53l4.88-7.82V6.5L9 5V3Zm3.5 7.22V6.05L13.05 5h-2.1l.55 1.05v4.17l-4.18 6.7h9.36l-4.18-6.7ZM8 19h8l-.62-1H8.62L8 19Z",
    label: "Safer use",
    title: "Drug checking and alerts",
    text: "Saferparty shares Swiss drug checking information, alerts, and counselling resources before and after the festival.",
    href: "https://en.saferparty.ch/angebote/drug-checking",
    action: "Open Saferparty",
    translations: {
      de: {
        label: "Safer Use",
        title: "Drug Checking und Warnungen",
        text: "Saferparty bietet Schweizer Informationen zu Drug Checking, Warnungen und Beratungsangeboten vor und nach dem Festival.",
        action: "Saferparty oeffnen",
      },
      fr: {
        label: "Usage plus sur",
        title: "Drug checking et alertes",
        text: "Saferparty partage des informations suisses sur le drug checking, les alertes et les ressources de conseil avant et apres le festival.",
        action: "Ouvrir Saferparty",
      },
      it: {
        label: "Uso piu sicuro",
        title: "Drug checking e allerte",
        text: "Saferparty condivide informazioni svizzere su drug checking, allerte e risorse di consulenza prima e dopo il festival.",
        action: "Apri Saferparty",
      },
    },
  },
] as const;

const languages = ["en", "de", "fr", "it"] as const;
---

<Layout
  title="ALPS Psycare — psy.cards"
  description="Burning Mountain harm-reduction combo chart with ALPS PsyCare resources for festival contexts."
  colorScheme="light"
>
  <main class="event-page">
    <header class="event-header">
      <nav class="event-controls" aria-label="Language selector">
        <div class="segmented-control">
          {
            languages.map((language) => (
              <button
                type="button"
                data-language={language}
                class:list={["control-button", language === "en" && "is-active"]}
                aria-pressed={language === "en" ? "true" : "false"}
              >
                {language.toUpperCase()}
              </button>
            ))
          }
        </div>
      </nav>

      <section class="hero" aria-labelledby="page-title">
        <div class="hero__copy">
          <div class="event-logos" aria-label="Event partners">
            <a
              href="https://www.burning-mountain.ch/"
              target="_blank"
              rel="noreferrer noopener"
              aria-label="Burning Mountain Festival"
            >
              <img
                src="/assets/burningmountain-logo.png"
                alt="Burning Mountain Festival"
                width="600"
                height="256"
              />
            </a>
            <span class="logo-divider" aria-hidden="true"></span>
            <a
              href="https://www.alps.foundation/"
              target="_blank"
              rel="noreferrer noopener"
              aria-label="ALPS PsyCare"
            >
              <img
                src="/assets/alps-psycare-logo.png"
                alt="ALPS PsyCare"
                width="1536"
                height="1024"
              />
            </a>
          </div>

          <p class="eyebrow" data-i18n="eyebrow">Burning Mountain Festival · Zernez</p>
          <h1 id="page-title" data-i18n="title">ALPS Psycare</h1>
          <p class="intro" data-i18n="intro">
            ALPS PsyCare brings science-based psychedelic education and
            non-judgmental psychological support into Swiss festival settings.
            By combining evidence-informed harm reduction, community care, and
            compassionate on-site support, the initiative helps people seek help
            early and prevents small difficulties from becoming serious
            incidents.
          </p>
        </div>

        <aside class="map-panel" aria-labelledby="map-title">
          <div class="map-frame">
            <img
              class="festival-map"
              src="/assets/burning-mountain-map.jpg"
              alt="Burning Mountain festival map"
              width="1003"
              height="1025"
            />
          </div>
          <div class="map-copy">
            <p class="map-label" data-i18n="mapLabel">Festival map</p>
            <h2 id="map-title" data-i18n="mapTitle">Burning Mountain site map</h2>
            <p data-i18n="mapText">
              Use the festival map to orient yourself on site. Check the latest
              signage and ask the info point, medical team, security, or PsyCare
              if you need help finding support.
            </p>
          </div>
        </aside>
      </section>
    </header>

    <section class="resources" aria-labelledby="resources-title">
      <div class="section-heading">
        <p class="eyebrow" data-i18n="resourcesEyebrow">Festival support</p>
        <h2 id="resources-title" data-i18n="resourcesTitle">Useful resources in the moment</h2>
      </div>

      <div class="resource-grid">
        {
          resources.map((resource) => (
            <article class="resource-card" data-resource={resource.key}>
              <p class="resource-label" data-resource-field="label">{resource.label}</p>
              <h3 data-resource-field="title">{resource.title}</h3>
              <p data-resource-field="text">{resource.text}</p>
              <a
                href={resource.href}
                target={resource.href.startsWith("http") ? "_blank" : undefined}
                rel={resource.href.startsWith("http") ? "noreferrer noopener" : undefined}
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                  <path d={resource.iconPath}></path>
                </svg>
                <span data-resource-field="action">{resource.action}</span>
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section id="combo-chart" class="chart-section" aria-labelledby="chart-title">
      <div class="section-heading section-heading--chart">
        <p class="eyebrow" data-i18n="chartEyebrow">Combination reference</p>
        <h2 id="chart-title" data-i18n="chartTitle">Drug combinations chart</h2>
        <p data-i18n="chartText">
          Use this as a quick reference, then speak with PsyCare, medical staff,
          or another trusted support person if something feels off.
        </p>
      </div>

      <ComboTable comboRoute="" initialSubstanceSet="common" />
      <Legend />
    </section>

    <footer class="disclaimer">
      <p>
        This table was compiled by TripSit using the best information available.
        <strong>Accuracy is not guaranteed.</strong> This table is only as valid
        as the labels on your drugs: <strong>always use a test kit.</strong>
        Absence of a warning does not imply an absence of danger. <strong
          >Further research is necessary.</strong
        >
      </p>
      <p>
        Do not rely solely on this chart. <strong
          >While taking certain medications,</strong
        > your risk is higher. Do your homework now to avoid problems later.
        <strong>Be safe out there.</strong> No one is invincible.
      </p>
    </footer>

    <Footer variant="wide" />
  </main>

  <div id="modal-slot" data-modal-slot></div>

  <script>
    import { initComboModal } from "../scripts/combo-modal.ts";
    initComboModal({
      rootRoute: window.location.pathname === "/" ? "/" : "/burning-mountain",
    });
  </script>

  <script define:vars={{ localizedContent, resources }}>
    const resourceCopy = Object.fromEntries(
      resources.map((resource) => [
        resource.key,
        {
          en: {
            label: resource.label,
            title: resource.title,
            text: resource.text,
            action: resource.action,
          },
          ...resource.translations,
        },
      ])
    );

    const setLanguage = (language) => {
      const copy = localizedContent[language] ?? localizedContent.en;
      document.documentElement.lang = language;

      document.querySelectorAll("[data-i18n]").forEach((element) => {
        const key = element.getAttribute("data-i18n");
        if (key && copy[key]) element.textContent = copy[key];
      });

      document.querySelectorAll("[data-resource]").forEach((card) => {
        const key = card.getAttribute("data-resource");
        const data = key ? resourceCopy[key]?.[language] ?? resourceCopy[key]?.en : null;
        if (!data) return;

        card.querySelectorAll("[data-resource-field]").forEach((element) => {
          const field = element.getAttribute("data-resource-field");
          if (field && data[field]) element.textContent = data[field];
        });
      });

      document.querySelectorAll("[data-language]").forEach((button) => {
        const isActive = button.getAttribute("data-language") === language;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", String(isActive));
      });
    };

    document.querySelectorAll("[data-language]").forEach((button) => {
      button.addEventListener("click", () => {
        const language = button.getAttribute("data-language") ?? "en";
        setLanguage(language);
      });
    });

  </script>
</Layout>

<style>
  .event-page {
    --color-ink: #ffffff;
    --color-ink-2: #f7f8f4;
    --color-ink-3: #ecefe6;
    --color-fg: #171813;
    --color-fg-mute: #62665b;
    --event-accent: rgb(232, 144, 9);
    --event-accent-soft: rgba(232, 144, 9, 0.13);
    --event-max: 1600px;
    --content-max: 1180px;
    min-height: 100dvh;
    padding: 0 0 48px;
    color: var(--color-fg);
    background:
      radial-gradient(circle at 8% 0%, rgba(232, 144, 9, 0.22), transparent 30rem),
      radial-gradient(circle at 88% 7%, rgba(232, 144, 9, 0.1), transparent 26rem),
      linear-gradient(180deg, #fffdf6 0%, #ffffff 560px);
  }

  .event-header {
    max-width: var(--event-max);
    margin: 0 auto;
    padding: 12px 16px 24px;
  }

  .event-controls {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: flex-start;
    gap: 8px 12px;
    margin: 0 0 18px;
    padding: 8px 0;
  }

  .segmented-control {
    display: inline-flex;
    flex: 0 0 auto;
    overflow: hidden;
    border: 1px solid rgba(23, 24, 19, 0.12);
    background: rgba(255, 255, 255, 0.76);
  }

  .control-button {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    min-height: 32px;
    padding: 0 10px;
    color: var(--color-fg-mute);
    font-size: 12px;
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
    border: 0;
    border-left: 1px solid rgba(23, 24, 19, 0.1);
    background: transparent;
    cursor: pointer;
  }

  .control-button:first-child {
    border-left: 0;
  }

  .control-button:hover,
  .control-button:focus-visible,
  .control-button.is-active {
    color: var(--color-fg);
    background: var(--event-accent-soft);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr);
    gap: clamp(20px, 4vw, 52px);
    align-items: center;
    max-width: var(--content-max);
    margin: 0 auto;
  }

  .hero__copy {
    min-width: 0;
  }

  .event-logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px 20px;
    margin: 0 0 24px;
  }

  .event-logos a {
    display: inline-flex;
    align-items: center;
    line-height: 0;
    text-decoration: none;
  }

  .event-logos img {
    display: block;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    filter: drop-shadow(0 12px 24px rgba(24, 25, 20, 0.13));
  }

  .event-logos a:first-child img {
    height: clamp(42px, 6vw, 74px);
  }

  .event-logos a:last-child img {
    height: clamp(48px, 7vw, 82px);
  }

  .logo-divider {
    width: 1px;
    height: 48px;
    background: rgba(23, 24, 19, 0.14);
  }

  .eyebrow,
  .map-label,
  .resource-label {
    margin: 0;
    color: var(--event-accent);
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.14em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 760px;
    margin: 8px 0 14px;
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.94;
  }

  .intro {
    max-width: 720px;
    margin: 0;
    color: color-mix(in oklab, var(--color-fg), var(--color-fg-mute) 22%);
    font-size: clamp(15px, 1.5vw, 19px);
    line-height: 1.46;
  }

  .map-panel {
    align-self: stretch;
    min-height: 0;
    display: grid;
    grid-template-rows: auto auto;
    overflow: hidden;
    border: 1px solid rgba(23, 24, 19, 0.13);
    background: #ffffff;
    box-shadow: 0 20px 54px rgba(24, 25, 20, 0.1);
  }

  .map-frame {
    position: relative;
    min-height: 0;
    overflow: hidden;
    background: #f1f0e7;
  }

  .festival-map {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1003 / 1025;
    object-fit: contain;
  }

  .map-copy {
    padding: 18px;
    border-top: 1px solid rgba(23, 24, 19, 0.1);
  }

  .map-copy h2 {
    margin: 8px 0 8px;
    font-size: clamp(20px, 2vw, 28px);
    line-height: 1.05;
  }

  .map-copy p:last-child {
    margin: 0;
    color: var(--color-fg-mute);
    font-size: 14px;
    line-height: 1.55;
  }

  .resources,
  .chart-section {
    max-width: var(--event-max);
    margin: 0 auto;
  }

  .resources {
    padding: 22px 16px 32px;
  }

  .section-heading {
    max-width: var(--content-max);
    margin: 0 auto 14px;
  }

  .section-heading h2 {
    margin: 8px 0 0;
    font-size: clamp(24px, 2.7vw, 38px);
    line-height: 1;
  }

  .section-heading p:last-child {
    max-width: 680px;
    margin: 10px 0 0;
    color: var(--color-fg-mute);
    font-size: 15px;
    line-height: 1.55;
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    max-width: var(--content-max);
    margin: 0 auto;
  }

  .resource-card {
    display: flex;
    min-height: 210px;
    flex-direction: column;
    align-items: flex-start;
    padding: 18px;
    border: 1px solid rgba(23, 24, 19, 0.11);
    background: #ffffff;
    box-shadow: 0 14px 40px rgba(24, 25, 20, 0.07);
  }

  .resource-card h3 {
    margin: 12px 0 10px;
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.05;
  }

  .resource-card p:not(.resource-label) {
    margin: 0 0 20px;
    color: var(--color-fg-mute);
    font-size: 14px;
    line-height: 1.55;
  }

  .resource-card a {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    min-height: 38px;
    padding: 0 14px;
    color: var(--color-fg);
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
    border: 1px solid rgba(23, 24, 19, 0.18);
    background: var(--event-accent-soft);
  }

  .resource-card a svg {
    flex: 0 0 auto;
    fill: currentColor;
  }

  .resource-card a:hover,
  .resource-card a:focus-visible {
    border-color: rgba(23, 24, 19, 0.32);
    background: rgba(232, 144, 9, 0.2);
  }

  .chart-section {
    padding-top: 2px;
  }

  .event-page :global(.table-wrap) {
    --cell-size: clamp(30px, 4vw, 48px);
  }

  .event-page :global(.category-nav) {
    position: static;
    left: auto;
    bottom: auto;
    z-index: 1;
    width: 100%;
    padding: 2px 0 0;
    background-color: rgba(255, 255, 255, 0.94);
    box-shadow: none;
    transform: none;
  }

  .event-page :global(.category-strip) {
    display: grid !important;
    grid-template-columns: 1fr !important;
    gap: 2px;
    margin-inline: 0 !important;
