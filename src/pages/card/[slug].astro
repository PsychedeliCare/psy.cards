---
import SubstanceCard from "../../components/SubstanceCard.astro";
import { columns, columnBySlug } from "../../data/config";

export const prerender = true;

export async function getStaticPaths() {
  return columns.map((col) => ({ params: { slug: col.slug } }));
}

const { slug } = Astro.params;
if (!slug) {
  return new Response("Not found", { status: 404 });
}

let substanceKey: string | undefined;

const col = columnBySlug.get(slug);
if (!col) return new Response("Not found", { status: 404 });
substanceKey = col.key;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>card</title>
  </head>
  <body>
    <div data-card-fragment>
      {substanceKey && <SubstanceCard substanceKey={substanceKey} />}
    </div>
  </body>
</html>
