---
import { Icon } from "@twodft/astro-icon/components";
import type { Dose } from "../../drugs/types/tripsit";
import {
  buildDoseCharts,
  formatDoseTick,
  getRouteIcon,
  getRouteLabel,
  type DoseChart,
} from "../lib/dose-chart";
import type { Locale } from "../i18n/locales";
import { getUiMessages } from "../i18n/load-locale";
import { t } from "../i18n/ui";

interface Props {
  formattedDose: Dose;
  doseNote?: string;
  locale?: Locale;
}

const { formattedDose, doseNote, locale = "en" } = Astro.props;
const ui = getUiMessages(locale);
const charts = buildDoseCharts(formattedDose);
const uid = crypto.randomUUID().slice(0, 8);
const hasChartable = charts.some((chart) => chart.chartable);

function isChart(chart: (typeof charts)[number]): chart is DoseChart {
  return chart.chartable;
}
---

<div class="dose-charts">
  <div class="doses-head">
    <h3>{t(locale, ui, "doseChart.title")}</h3>
    {
      hasChartable && (
        <div class="dose-view-toggle" role="radiogroup" aria-label={t(locale, ui, "doseChart.title")}>
          <input
            type="radio"
            name={`dose-view-${uid}`}
            id={`dose-view-chart-${uid}`}
            class="dose-view-radio dose-view-radio--chart"
            checked
          />
          <label
            class="dose-view-btn"
            for={`dose-view-chart-${uid}`}
            title={t(locale, ui, "doseChart.chart")}
          >
            <Icon name="tabler:chart-bar" aria-hidden="true" />
            <span class="sr-only">{t(locale, ui, "doseChart.chart")}</span>
          </label>
          <input
            type="radio"
            name={`dose-view-${uid}`}
            id={`dose-view-table-${uid}`}
            class="dose-view-radio dose-view-radio--table"
          />
          <label
            class="dose-view-btn"
            for={`dose-view-table-${uid}`}
            title={t(locale, ui, "doseChart.table")}
          >
            <Icon name="tabler:table" aria-hidden="true" />
            <span class="sr-only">{t(locale, ui, "doseChart.table")}</span>
          </label>
        </div>
      )
    }
  </div>

  {
    charts.map((chart) =>
      isChart(chart) ? (
        <div class="dose-route">
          <div class="dose-route-head">
            <Icon
              name={`tabler:${getRouteIcon(chart.route)}`}
              class="dose-route-icon"
              aria-hidden="true"
            />
            <span class="dose-route-label">{getRouteLabel(chart.route)}</span>
            <span class="dose-route-unit">{chart.unit}</span>
          </div>

          <div class="dose-plot" aria-hidden="true">
            <span class="dose-line" />

            <div class="dose-segments">
              {chart.segments.map((segment, segmentIndex) => (
                <div
                  class:list={[
                    "dose-segment",
                    { "dose-segment--point": segment.isPoint },
                  ]}
                  data-level={segment.level}
                  data-open={segment.openEnd ? "" : undefined}
                  style={`--left: ${segment.left}%; --width: ${segment.width}%; --bar-color: ${segment.color}`}
                  title={`${segment.label}: ${segment.amount}`}
                >
                  <span class="dose-cat">{segment.label}</span>
                  {segment.isPoint ? (
                    <span class="dose-point" />
                  ) : (
                    <>
                      <span
                        class:list={[
                          "dose-bar",
                          { "dose-bar-open": segment.openEnd },
                        ]}
                      />
                      <span class="dose-range" />
                    </>
                  )}
                  {segment.showStart && (
                    <span
                      class:list={[
                        "dose-bound dose-bound-start",
                        { "dose-bound--first": segment.showStart && segment.start === 0 },
                      ]}
                    >
                      {formatDoseTick(segment.start)}
                      <span class="dose-bound-unit">{chart.unit}</span>
                    </span>
                  )}
                  {segment.showEnd && (
                    <span
                      class:list={[
                        "dose-bound dose-bound-end",
                        {
                          "dose-bound--last":
                            segmentIndex === chart.segments.length - 1,
                        },
                      ]}
                    >
                      {formatDoseTick(segment.end)}
                      <span class="dose-bound-unit">{chart.unit}</span>
                      {segment.openEnd && (
                        <span class="dose-bound-plus">+</span>
                      )}
                    </span>
                  )}
                </div>
              ))}
            </div>
          </div>

          <table class="dose-table" aria-hidden="true">
            <tbody>
              {chart.segments.map((segment) => (
                <tr>
                  <th scope="row">
                    <span
                      class="dose-table-dot"
                      style={`--bar-color: ${segment.color}`}
                    />
                    {segment.label}
                  </th>
                  <td>{segment.amount}</td>
                </tr>
              ))}
            </tbody>
          </table>

          <table class="dose-chart-sr">
            <caption>{getRouteLabel(chart.route)} dosage ranges</caption>
            <thead>
              <tr>
                <th scope="col">Level</th>
                <th scope="col">Amount</th>
              </tr>
            </thead>
            <tbody>
              {chart.segments.map((segment) => (
                <tr>
                  <th scope="row">{segment.label}</th>
                  <td>{segment.amount}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="dose-route dose-route-fallback">
          <div class="dose-route-head">
            <Icon
              name={`tabler:${getRouteIcon(chart.route)}`}
              class="dose-route-icon"
              aria-hidden="true"
            />
            <span class="dose-route-label">{getRouteLabel(chart.route)}</span>
          </div>
          <table class="dose-fallback-table">
            <thead>
              <tr>
                <th scope="col">Level</th>
                <th scope="col">Amount</th>
              </tr>
            </thead>
            <tbody>
              {chart.rows.map((row) => (
                <tr>
                  <th scope="row">{row.level}</th>
                  <td>{row.amount}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )
    )
  }
  {doseNote && <p class="note">{doseNote}</p>}
</div>
