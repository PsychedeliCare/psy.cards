---
import Icon from "./Icon.astro";
import { legendDefinitions } from "../data/definitions";
---

<aside class="legend" aria-label="Legend">
  <ul>
    {
      legendDefinitions.map((def) => (
        <li class={`status-${def.statusKey}`}>
          <span class="chip status-surface">
            <Icon name={def.icon} size="0.95em" />
          </span>
          <span class="body">
            <span class="label">{def.label}</span>
            <span class="definition">{def.definition}</span>
          </span>
        </li>
      ))
    }
  </ul>
</aside>

<style>
  .legend {
    width: 100%;
    padding: 18px 16px 6px;
  }

  .legend ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px 18px;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  }

  .legend li {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 12px;
    line-height: 1.45;
    color: var(--color-fg);
  }

  .chip {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: currentColor;
    color-scheme: dark;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06);
  }

  .chip :global(svg) {
    color: #fff;
    filter: drop-shadow(0 0 2px rgba(0, 0, 0, 0.5));
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .label {
    font-weight: 600;
    color: var(--color-fg);
  }

  .definition {
    color: var(--color-fg-mute);
    font-size: 11.5px;
  }
</style>
