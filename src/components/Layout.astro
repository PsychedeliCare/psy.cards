---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "psy.cards — Drug combinations",
  description = "Responsive harm-reduction reference for drug interactions, sourced from TripSit.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
