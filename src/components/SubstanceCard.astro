---
import { Icon } from "@twodft/astro-icon/components";
import DoseChart from "./DoseChart.astro";
import {
  getDrugByKey,
  isDrugClass,
  getClassDescription,
  getDisplayName,
} from "../data/drugs";
import { columnByKey } from "../data/config";
import { getEffectIcon } from "../data/effect-icons";
import { getSubstanceStructure } from "../data/substances";
import { toTitleCase } from "../lib/text";
import MoleculeFigure from "./MoleculeFigure.astro";
import SmilesCitation from "./SmilesCitation.astro";
import TimingChart from "./TimingChart.astro";

interface Props {
  substanceKey: string;
}

const { substanceKey } = Astro.props;

const column = columnByKey.get(substanceKey);
const drug = getDrugByKey(substanceKey);
const displayName = drug?.pretty_name ?? getDisplayName(substanceKey);
const classNote = getClassDescription(substanceKey);

const categories = drug?.categories ?? drug?.properties?.categories ?? [];
const props = drug?.properties ?? {};
const summary = props.summary ?? classNote;

function firstDurationValue(
  d: Record<string, unknown> | undefined
): string | undefined {
  if (!d) return undefined;
  const entries = Object.entries(d).filter(
    ([k, v]) => k !== "_unit" && typeof v === "string" && v
  );
  if (!entries.length) return undefined;
  return entries.map(([k, v]) => (k === "value" ? v : `${v} (${k})`)).join(", ");
}

const formattedOnset = drug?.formatted_onset as Record<string, unknown> | undefined;
const formattedDuration = drug?.formatted_duration as
  | Record<string, unknown>
  | undefined;
const formattedAftereffects = drug?.formatted_aftereffects as
  | Record<string, unknown>
  | undefined;

const onsetVal = firstDurationValue(formattedOnset);
const onsetUnit = formattedOnset?._unit;
const durationVal = firstDurationValue(formattedDuration);
const durationUnit = formattedDuration?._unit;
const afterVal = firstDurationValue(formattedAftereffects);
const afterUnit = formattedAftereffects?._unit;
const rawPeakVal = (props as Record<string, unknown>).peak;
const peakVal: string | Record<string, unknown> | undefined =
  typeof rawPeakVal === "string" ||
  (rawPeakVal !== null && typeof rawPeakVal === "object")
    ? (rawPeakVal as string | Record<string, unknown>)
    : undefined;

const effects = drug?.formatted_effects ?? [];
const links = drug?.links ?? undefined;
const pweffects = drug?.pweffects ?? undefined;
const pwEffectEntries =
  pweffects ? Object.entries(pweffects) : [];
const hasEffects = effects.length > 0 || pwEffectEntries.length > 0;
const hasStructure = Boolean(getSubstanceStructure(substanceKey));
---

<article
  class={`substance-card${column ? ` group-${column.group}` : ""}`}
  data-card-type="substance"
  data-substance-key={substanceKey}
>
  <MoleculeFigure substanceKey={substanceKey} />
  <header class="card-header">
    <div class="card-header-body">
      <div class="accent category-surface" aria-hidden="true"></div>
      <div class="title">
        <h2 id="card-heading">{displayName}</h2>
        {
          categories.length > 0 && (
            <ul class="tags">
              {categories.map((c) => (
                <li>{c}</li>
              ))}
            </ul>
          )
        }
      </div>
    </div>
  </header>

  {summary && <p class="summary">{summary}</p>}

  {
    !drug && isDrugClass(substanceKey) && (
      <p class="fallback-note">
        This column represents a drug class rather than a single compound, so
        specific dose and duration data isn't available here.
      </p>
    )
  }

  {
    !drug && !classNote && (
      <p class="fallback-note">
        Detailed substance data isn't available in the TripSit dataset for this
        entry. Combination data is still accurate.
      </p>
    )
  }

  {
    (onsetVal || durationVal || afterVal) && (
      <section class="timings">
        <div class="timings-table">
          <h3>Timing</h3>
          <dl>
            {onsetVal && (
              <div>
                <dt>Onset</dt>
                <dd>
                  {onsetVal} <span class="unit">{onsetUnit}</span>
                </dd>
              </div>
            )}
            {durationVal && (
              <div>
                <dt>Duration</dt>
                <dd>
                  {durationVal} <span class="unit">{durationUnit}</span>
                </dd>
              </div>
            )}
            {afterVal && (
              <div>
                <dt>After-effects</dt>
                <dd>
                  {afterVal} <span class="unit">{afterUnit}</span>
                </dd>
              </div>
            )}
            {props["half-life"] && (
              <div>
                <dt>Half-life</dt>
                <dd>{props["half-life"]}</dd>
              </div>
            )}
          </dl>
        </div>
        <TimingChart
          formattedOnset={formattedOnset}
          formattedDuration={formattedDuration}
          peak={peakVal}
          label={`${displayName} effect timeline`}
        />
      </section>
    )
  }

  {
    drug?.formatted_dose && (
      <section class="doses">
        <DoseChart
          formattedDose={drug.formatted_dose}
          doseNote={drug.dose_note}
        />
      </section>
    )
  }

  {
    (props.avoid || props.warning || props["test-kits"]) && (
      <section class="advice">
        <h3>Safety</h3>
        <dl>
          {props.warning && (
            <div>
              <dt>Warning</dt>
              <dd>{props.warning}</dd>
            </div>
          )}
          {props.avoid && (
            <div>
              <dt>Avoid combining with</dt>
              <dd>{props.avoid}</dd>
            </div>
          )}
          {props["test-kits"] && (
            <div>
              <dt>Test kits</dt>
              <dd>{props["test-kits"]}</dd>
            </div>
          )}
        </dl>
      </section>
    )
  }

  {
    hasEffects && (
      <section class="effects">
        <h3>Effects</h3>
        {
          effects.length > 0 && (
            <ul class="pills">
              {effects.map((e) => (
                <li>
                  <Icon
                    name={`tabler:${getEffectIcon(e)}`}
                    class="effect-icon"
                    aria-hidden="true"
                  />
                  {toTitleCase(e)}
                </li>
              ))}
            </ul>
          )
        }
        {
          pwEffectEntries.length > 0 && (
            <div class="pw-effects-well">
              <details class="pw-effects">
                <summary class="pw-effects-toggle">
                  <span class="pw-effects-toggle-main">
                    <img
                      src="/assets/psychonautwiki-logo.png"
                      alt=""
                      width="72"
                      height="20"
                      decoding="async"
                    />
                    <span class="pw-effects-label">
                      View PsychonautWiki effects
                    </span>
                    <span class="pw-effects-count">
                      ({pwEffectEntries.length})
                    </span>
                  </span>
                  <Icon
                    name="tabler:chevron-down"
                    class="pw-effects-chevron"
                    aria-hidden="true"
                  />
                </summary>
                <ul class="pills">
                  {pwEffectEntries.map(([label, href]) => (
                    <li>
                      <a
                        href={href}
                        target="_blank"
                        rel="noreferrer noopener"
                      >
                        {label}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            </div>
          )
        }
      </section>
    )
  }

  {
    links && (
      <section class="links">
        <h3>More</h3>
        <ul class="inline-links">
          {links.experiences && (
            <li>
              <a href={links.experiences} target="_blank" rel="noreferrer noopener">
                Trip reports
              </a>
            </li>
          )}
          {links.pihkal && (
            <li>
              <a href={links.pihkal} target="_blank" rel="noreferrer noopener">
                PiHKAL
              </a>
            </li>
          )}
          {links.tihkal && (
            <li>
              <a href={links.tihkal} target="_blank" rel="noreferrer noopener">
                TiHKAL
              </a>
            </li>
          )}
        </ul>
      </section>
    )
  }

  {hasStructure && <SmilesCitation />}
</article>

