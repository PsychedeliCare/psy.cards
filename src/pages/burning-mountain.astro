---
import Layout from "../components/Layout.astro";
import ComboTable from "../components/ComboTable.astro";
import Legend from "../components/Legend.astro";
import Footer from "../components/Footer.astro";
import Disclaimer from "../components/Disclaimer.astro";
import Modal from "../components/Modal.astro";
import SubstanceCard from "../components/SubstanceCard.astro";
import { getUiMessages } from "../i18n/load-locale";
import type { Locale } from "../i18n/locales";

export const prerender = true;

interface Props {
  locale?: Locale;
  modalSubstanceKey?: string;
}

const { locale = "en", modalSubstanceKey } = Astro.props;

type ResourceCopy = {
  label: string;
  title: string;
  text: string;
  action: string;
};

type EventResource = ResourceCopy & {
  key: string;
  iconPath: string;
  href: string;
};

const uiByLocale = {
  en: getUiMessages("en"),
  de: getUiMessages("de"),
  fr: getUiMessages("fr"),
  it: getUiMessages("it"),
} as const;

const bmMessages = uiByLocale[locale].burningMountain as Record<string, unknown>;
const bmUi = bmMessages as Record<string, string>;
const resourcesConfig = bmMessages.resources as Record<
  string,
  ResourceCopy
>;
const eventRoute = locale === "en" ? "/burning-mountain" : `/${locale}/burning-mountain`;
const eventSubstanceBase = `${eventRoute}/`;

const resources = [
  {
    key: "emergency",
    iconPath:
      "M12 2.25 3.25 6.1v5.9c0 5.05 3.5 8.22 8.75 9.75 5.25-1.53 8.75-4.7 8.75-9.75V6.1L12 2.25Zm1 5.75v3h3v2h-3v3h-2v-3H8v-2h3V8h2Z",
    href: "tel:144",
    ...resourcesConfig.emergency,
  },
  {
    key: "festival",
    iconPath:
      "M4 4h16v12H5.5L4 18.5V4Zm3 3v2h10V7H7Zm0 4v2h7v-2H7Zm-1 10h12v-2H6v2Z",
    href: "https://www.burning-mountain.ch/",
    ...resourcesConfig.festival,
  },
  {
    key: "saferUse",
    iconPath:
      "M9 3h6v2l-1.5 1.5v3.15l4.88 7.82A2.3 2.3 0 0 1 16.42 21H7.58a2.3 2.3 0 0 1-1.96-3.53l4.88-7.82V6.5L9 5V3Zm3.5 7.22V6.05L13.05 5h-2.1l.55 1.05v4.17l-4.18 6.7h9.36l-4.18-6.7ZM8 19h8l-.62-1H8.62L8 19Z",
    href: "https://en.saferparty.ch/angebote/drug-checking",
    ...resourcesConfig.saferUse,
  },
] satisfies EventResource[];
---

<Layout
  locale={locale}
  title={bmUi.title}
  description={bmUi.description}
  colorScheme="light"
  headerVariant="event"
  comboRoute={eventRoute}
  substanceBase={eventSubstanceBase}
>
  <main class="event-page">
    <header class="event-header">
      <section class="hero" aria-labelledby="page-title">
        <div class="hero__copy">
          <div class="event-logos" aria-label="Event partners">
            <a
              href="https://www.burning-mountain.ch/"
              target="_blank"
              rel="noreferrer noopener"
              aria-label="Burning Mountain Festival"
            >
              <img
                src="/assets/burningmountain-logo.png"
                alt="Burning Mountain Festival"
                width="600"
                height="256"
              />
            </a>
            <span class="logo-divider" aria-hidden="true"></span>
            <a
              href="https://www.alps.foundation/"
              target="_blank"
              rel="noreferrer noopener"
              aria-label="ALPS PsyCare"
            >
              <img
                src="/assets/alps-psycare-logo.png"
                alt="ALPS PsyCare"
                width="1536"
                height="1024"
              />
            </a>
          </div>

          <p class="eyebrow">{bmUi.eyebrow}</p>
          <h1 id="page-title">{bmUi.pageTitle}</h1>
          <p class="intro">{bmUi.intro}</p>
        </div>

        <aside class="map-panel" aria-labelledby="map-title">
          <div class="map-frame">
            <img
              class="festival-map"
              src="/assets/burning-mountain-map.jpg"
              alt="Burning Mountain festival map"
              width="1003"
              height="1025"
            />
          </div>
          <div class="map-copy">
            <p class="map-label">{bmUi.mapLabel}</p>
            <h2 id="map-title">{bmUi.mapTitle}</h2>
            <p>{bmUi.mapText}</p>
          </div>
        </aside>
      </section>
    </header>

    <section class="resources" aria-labelledby="resources-title">
      <div class="section-heading">
        <p class="eyebrow">{bmUi.resourcesEyebrow}</p>
        <h2 id="resources-title">{bmUi.resourcesTitle}</h2>
      </div>

      <div class="resource-grid">
        {
          resources.map((resource) => (
            <article class="resource-card" data-resource={resource.key}>
              <p class="resource-label" data-resource-field="label">{resource.label}</p>
              <h3 data-resource-field="title">{resource.title}</h3>
              <p data-resource-field="text">{resource.text}</p>
              <a
                href={resource.href}
                target={resource.href.startsWith("http") ? "_blank" : undefined}
                rel={resource.href.startsWith("http") ? "noreferrer noopener" : undefined}
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                  <path d={resource.iconPath}></path>
                </svg>
                <span data-resource-field="action">{resource.action}</span>
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section id="combo-chart" class="chart-section" aria-labelledby="chart-title">
      <div class="section-heading section-heading--chart">
        <p class="eyebrow">{bmUi.chartEyebrow}</p>
        <h2 id="chart-title">{bmUi.chartTitle}</h2>
        <p>{bmUi.chartText}</p>
      </div>

      <ComboTable
        locale={locale}
        comboRoute={eventRoute}
        substanceBase={eventSubstanceBase}
        initialSubstanceSet="common"
      />
      <Legend locale={locale} />
    </section>

    <Disclaimer locale={locale} />

    <Footer locale={locale} variant="wide" />
  </main>

  <div id="modal-slot" data-modal-slot>
    {
      modalSubstanceKey && (
        <Modal open={true} labelledBy="card-heading" locale={locale}>
          <SubstanceCard substanceKey={modalSubstanceKey} locale={locale} />
        </Modal>
      )
    }
  </div>

  <script>
    import { initComboModal } from "../scripts/combo-modal.ts";
    initComboModal();
  </script>
</Layout>

<style>
  .event-page {
    --event-accent: #f5a71d;
    --event-accent-strong: #df6330;
    --event-accent-deep: #372f4c;
    --event-cream: #fff0d2;
    --event-surface: #fffaf1;
    --event-line: rgba(55, 47, 76, 0.15);
    --event-accent-soft: rgba(245, 167, 29, 0.16);
    --event-max: 1600px;
    --content-max: 1180px;
    min-height: 100dvh;
    color: var(--color-fg);
    background:
      radial-gradient(circle at 10% 0%, rgba(245, 167, 29, 0.32), transparent 30rem),
      radial-gradient(circle at 88% 4%, rgba(223, 99, 48, 0.2), transparent 28rem),
      radial-gradient(circle at 52% -10%, rgba(55, 47, 76, 0.16), transparent 24rem),
      linear-gradient(180deg, var(--event-cream) 0%, var(--event-surface) 460px, #ffffff 980px);
  }

  .event-header {
    max-width: var(--event-max);
    margin: 0 auto;
    padding: 20px 16px 24px;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr);
    gap: clamp(20px, 4vw, 52px);
    align-items: center;
    max-width: var(--content-max);
    margin: 0 auto;
  }

  .hero__copy {
    min-width: 0;
  }

  .event-logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px 20px;
    margin: 0 0 24px;
  }

  .event-logos a {
    display: inline-flex;
    align-items: center;
    line-height: 0;
    text-decoration: none;
  }

  .event-logos img {
    display: block;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    filter: drop-shadow(0 14px 24px rgba(55, 47, 76, 0.17));
  }

  .event-logos a:first-child img {
    height: clamp(42px, 6vw, 74px);
  }

  .event-logos a:last-child img {
    height: clamp(48px, 7vw, 82px);
  }

  .logo-divider {
    width: 1px;
    height: 48px;
    background: var(--event-line);
  }

  .eyebrow,
  .map-label,
  .resource-label {
    margin: 0;
    color: var(--event-accent-strong);
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.14em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 760px;
    margin: 8px 0 14px;
    color: var(--event-accent-deep);
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.94;
  }

  .intro {
    max-width: 720px;
    margin: 0;
    color: color-mix(in oklab, var(--color-fg), var(--color-fg-mute) 22%);
    font-size: clamp(15px, 1.5vw, 19px);
    line-height: 1.46;
  }

  .map-panel {
    align-self: stretch;
    min-height: 0;
    display: grid;
    grid-template-rows: auto auto;
    overflow: hidden;
    border: 1px solid var(--event-line);
    border-radius: 24px;
    background: var(--event-surface);
    box-shadow: 0 22px 58px rgba(55, 47, 76, 0.13);
  }

  .map-frame {
    position: relative;
    min-height: 0;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(245, 167, 29, 0.14), rgba(55, 47, 76, 0.08)),
      #f4ead8;
  }

  .festival-map {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1003 / 1025;
    object-fit: contain;
  }

  .map-copy {
    padding: 18px;
    border-top: 1px solid var(--event-line);
  }

  .map-copy h2 {
    margin: 8px 0 8px;
    font-size: clamp(20px, 2vw, 28px);
    line-height: 1.05;
  }

  .map-copy p:last-child {
    margin: 0;
    color: var(--color-fg-mute);
    font-size: 14px;
    line-height: 1.55;
  }

  .resources,
  .chart-section {
    max-width: var(--event-max);
    margin: 0 auto;
  }

  .resources {
    padding: 22px 16px 32px;
  }

  .section-heading {
    max-width: var(--content-max);
    margin: 0 auto 14px;
  }

  .section-heading h2 {
    margin: 8px 0 0;
    font-size: clamp(24px, 2.7vw, 38px);
    line-height: 1;
  }

  .section-heading p:last-child {
    max-width: 680px;
    margin: 10px 0 0;
    color: var(--color-fg-mute);
    font-size: 15px;
    line-height: 1.55;
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    max-width: var(--content-max);
    margin: 0 auto;
  }

  .resource-card {
    position: relative;
    display: flex;
    min-height: 210px;
    flex-direction: column;
    align-items: flex-start;
    overflow: hidden;
    padding: 18px;
    border: 1px solid var(--event-line);
    border-radius: 20px;
    background:
      linear-gradient(145deg, rgba(245, 167, 29, 0.12), rgba(255, 250, 241, 0) 42%),
      #ffffff;
    box-shadow: 0 16px 42px rgba(55, 47, 76, 0.09);
  }

  .resource-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 4px;
    background: linear-gradient(90deg, var(--event-accent), var(--event-accent-strong), var(--event-accent-deep));
  }

  .resource-card h3 {
    margin: 12px 0 10px;
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.05;
  }

  .resource-card p:not(.resource-label) {
    margin: 0 0 20px;
    color: var(--color-fg-mute);
    font-size: 14px;
    line-height: 1.55;
  }

  .resource-card a {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    min-height: 38px;
    padding: 0 14px;
    color: var(--event-accent-deep);
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
    border: 1px solid rgba(55, 47, 76, 0.2);
    border-radius: 999px;
    background:
      linear-gradient(135deg, rgba(245, 167, 29, 0.22), rgba(223, 99, 48, 0.1)),
      #fff8e8;
  }

  .resource-card a svg {
    flex: 0 0 auto;
    fill: currentColor;
  }

  .resource-card a:hover,
  .resource-card a:focus-visible {
    border-color: rgba(55, 47, 76, 0.36);
    background:
      linear-gradient(135deg, rgba(245, 167, 29, 0.3), rgba(223, 99, 48, 0.16)),
      #fff3d5;
  }

  .chart-section {
    padding-top: 2px;
  }

  .event-page :global(.table-wrap) {
    --cell-size: clamp(30px, 4vw, 48px);
  }

  .section-heading--chart {
    padding: 0 16px;
  }

  .chart-section :global(.table-wrap) {
    margin-top: 20px;
  }

  .disclaimer {
    max-width: 860px;
    padding: 20px 16px 0;
    font-size: 12.5px;
    line-height: 1.6;
    color: var(--color-fg-mute);
  }

  .disclaimer p {
    margin: 0 0 10px;
  }

  .disclaimer strong {
    color: var(--color-fg);
    font-weight: 600;
  }

  .event-page :global(.site-footer) {
    border-top-color: var(--event-line);
  }

  .event-page :global(.project-link),
  .event-page :global(.partner-link img) {
    filter: grayscale(100%) contrast(0.92);
    opacity: 0.72;
  }

  .event-page :global(.project-link:hover),
  .event-page :global(.project-link:focus-visible),
  .event-page :global(.partner-link:hover img),
  .event-page :global(.partner-link:focus-visible img) {
    filter: grayscale(100%) contrast(1);
    opacity: 0.94;
  }

  .event-page :global(.contribute-link) {
    color: var(--event-accent-deep);
    border-color: rgba(55, 47, 76, 0.2);
    background:
      linear-gradient(135deg, rgba(245, 167, 29, 0.2), rgba(223, 99, 48, 0.1)),
      #fff8e8;
    box-shadow: 0 10px 24px rgba(55, 47, 76, 0.08);
  }

  .event-page :global(.contribute-link:hover),
  .event-page :global(.contribute-link:focus-visible) {
    border-color: rgba(55, 47, 76, 0.34);
    background:
      linear-gradient(135deg, rgba(245, 167, 29, 0.28), rgba(223, 99, 48, 0.15)),
      #fff2d6;
  }

  .event-page :global(.contribute-link img) {
    filter: none;
    opacity: 0.88;
  }

  @media (max-width: 920px) {
    .hero {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .map-panel {
      min-height: 0;
    }

    .resource-grid {
      grid-template-columns: 1fr;
    }

    .resource-card {
      min-height: 0;
    }

  }

  @media (max-width: 640px) {
    .event-header {
      padding: 8px 12px 20px;
    }

    .event-logos {
      align-items: flex-start;
      gap: 10px 14px;
      margin-bottom: 18px;
    }

    .event-logos a:first-child img {
      height: 42px;
    }

    .event-logos a:last-child img {
      height: 50px;
    }

    h1 {
      margin-bottom: 10px;
      font-size: clamp(34px, 14vw, 54px);
    }

    .intro {
      font-size: 15px;
      line-height: 1.42;
    }

    .resources {
      padding: 20px 12px 26px;
    }

    .section-heading--chart {
      padding: 0 12px;
    }

    .logo-divider {
      display: none;
    }

    .map-copy,
    .resource-card {
      padding: 14px;
    }

    .event-page :global(.table-wrap) {
      --cell-size: 41px;
    }

  }
</style>
