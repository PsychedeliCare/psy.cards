---
import type { IconName } from "../data/definitions";

interface Props {
  name: IconName;
  size?: number | string;
  class?: string;
  title?: string;
}

const { name, size = "1em", class: className = "", title } = Astro.props;
---

{
  name === "arrow-up" && (
    <svg
      viewBox="0 0 24 24"
      width={size}
      height={size}
      class={className}
      aria-hidden={title ? undefined : "true"}
      role={title ? "img" : undefined}
      fill="currentColor"
    >
      {title && <title>{title}</title>}
      <path d="M11 20V7.83l-5.17 5.17L4 11l8-8 8 8-1.83 1.83L13 7.83V20z" />
    </svg>
  )
}
