---
import SubstancePage from "../../views/SubstancePage.astro";
import { getColumns } from "../../data/config";

export const prerender = true;

export async function getStaticPaths() {
  return getColumns("it").map((col) => ({ params: { slug: col.slug } }));
}

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect("/it/combos");
}
---

<SubstancePage locale="it" slug={slug} />
