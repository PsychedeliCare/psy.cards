---
import ComboCell from "./ComboCell.astro";
import {
  columns,
  groupLabels,
  visibleGroupOrder,
  type GroupName,
} from "../data/config";

const TOP_COUNT = 10;
const topSubstances = new Set([
  "lsd",
  "mushrooms",
  "cannabis",
  "mdma",
  "cocaine",
  "alcohol",
  "amphetamines",
  "ketamine",
  "benzodiazepines",
  "opioids",
]);

const topColumns = columns.filter((c) => topSubstances.has(c.key));
const extraColumns = columns.filter((c) => !topSubstances.has(c.key));

const categorySummaries: Array<{ group: GroupName; text: string }> = [
  {
    group: "stimulant",
    text: "Racing heartbeat, sweating, energy, confidence, well-being, arousal, euphoria, lowered appetite, clenched jaws, dilated pupils, paranoia, anxiety, mood swings, impotence",
  },
  {
    group: "empathogen",
    text: "Belonging, arousal, understanding, sweating, serotonin syndrome, erectile dysfunction, warmth, overheat, overdose, risk of dehydration or overhydration",
  },
  {
    group: "psychedelic",
    text: "Visual disturbance, spiritual connection, loss of control, heightened senses, opened doors of perception, panic, mood swings, arousal, fear, vomiting, mental health harms",
  },
  {
    group: "dissociative",
    text: "Euphoria, numb, safe, pain-free, floaty, relaxed, protected, happy, unaware, unconscious, in a 'hole', perceptual disturbances, scared, disconnected, vulnerable",
  },
  {
    group: "depressant",
    text: "Relaxed, confident, care-free, risk-taking, unconscious, coma, euphoria, death, disinhibited behaviours, blackouts, sleep, vomiting, nausea, aggression, dependence",
  },
  {
    group: "opioid",
    text: "Confident, pain-free, safe, sleepy, warm, feel invincible, itchy, constricted pupils, stop breathing, nausea, vomiting, euphoria, sweating, overdose, dependence, withdrawal",
  },
  {
    group: "cannabinoid",
    text: "Calm, relaxed, chilled out, floaty, reduced pain, paranoia, anxiety, loss of memory, bloodshot eyes, increased sensuality, dry mouth, overexcited, changes to appetite",
  },
];

function getLabelSizeClass(label: string) {
  if (label.length >= 11) return "label-xs";
  if (label.length >= 8) return "label-sm";
  return "label-md";
}
---

<section class="table-wrap" aria-label="Drug combinations" data-expanded="false">
  <div class="shadow-left" aria-hidden="true" data-table-shadow></div>
  <div class="table-head-stick">
    <div class="corner" aria-hidden="true">
      <button class="expand-toggle" type="button" data-expand-toggle aria-pressed="false">
        <span class="expand-label" data-expand-label>Show all</span>
      </button>
    </div>
    <div class="table-head-scroll" data-head-scroll>
      <table class="combos-table combos-table--head" role="presentation">
        <thead>
          <tr>
            {
              columns.map((col) => (
                <th
                  scope="col"
                  class={`col-head group-${col.group} category-surface cell-text ${getLabelSizeClass(col.label)}`}
                  data-substance-slug={col.slug}
                  data-col-key={col.key}
                  data-col-group={col.group}
                  data-is-top={topSubstances.has(col.key) ? "true" : "false"}
                  data-hover-cell
                >
                  <a
                    href={`/${col.slug}`}
                    class="label-link col-link"
                    data-substance={`/${col.slug}`}
                  >
                    <span class="label-text">{col.label}</span>
                  </a>
                </th>
              ))
            }
          </tr>
        </thead>
      </table>
    </div>
  </div>

  <div class="table-scroll" role="region" tabindex="0" data-body-scroll>
    <table class="combos-table combos-table--body" role="grid">
      <tbody>
        {
          columns.map((row) => (
            <tr data-row-substance={row.key} data-is-top={topSubstances.has(row.key) ? "true" : "false"}>
              <th
                scope="row"
                class={`row-head group-${row.group} category-surface cell-text ${getLabelSizeClass(row.label)}`}
                data-substance-slug={row.slug}
                data-row-key={row.key}
                data-row-group={row.group}
                data-is-top={topSubstances.has(row.key) ? "true" : "false"}
                data-hover-cell
              >
                <a
                  href={`/${row.slug}`}
                  class="label-link row-link"
                  data-substance={`/${row.slug}`}
                >
                  <span class="label-text">{row.label}</span>
                </a>
              </th>
              {columns.map((col) =>
                row.key === col.key ? (
                  <th
                    scope="col"
                    class={`diag group-${row.group} category-surface cell-text ${getLabelSizeClass(row.label)}`}
                    data-row-key={row.key}
                    data-col-key={col.key}
                    data-row-group={row.group}
                    data-col-group={col.group}
                    data-is-top-row={topSubstances.has(row.key) ? "true" : "false"}
                    data-is-top-col={topSubstances.has(col.key) ? "true" : "false"}
                    data-hover-cell
                  >
                    <a
                      href={`/${row.slug}`}
                      class="label-link diag-link"
                      data-substance={`/${row.slug}`}
                    >
                      <span class="label-text">{row.label}</span>
                    </a>
                  </th>
                ) : (
                  <td
                    class="cell-td"
                    data-row-key={row.key}
                    data-col-key={col.key}
                    data-row-group={row.group}
                    data-col-group={col.group}
                    data-is-top-row={topSubstances.has(row.key) ? "true" : "false"}
                    data-is-top-col={topSubstances.has(col.key) ? "true" : "false"}
                    data-hover-cell
                  >
                    <ComboCell
                      rowKey={row.key}
                      colKey={col.key}
                      rowLabel={row.label}
                      colLabel={col.label}
                    />
                  </td>
                )
              )}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>

<nav class="category-nav" aria-label="Drug categories">
  <div class="category-strip">
    {
      categorySummaries.map((category) => (
        <div class={`category-card group-${category.group} category-surface`} data-category={category.group}>
          <label class="category-toggle">
            <input
              type="checkbox"
              checked
              data-category-checkbox={category.group}
              class="category-checkbox"
            />
            <span class="category-heading">{groupLabels[category.group]}</span>
          </label>
          <p>{category.text}</p>
        </div>
      ))
    }
  </div>

  <p class="category-credit">
    Categories adapted from <a href="https://www.thedrugswheel.com/" target="_blank" rel="noreferrer noopener">The Drugs Wheel</a>.
  </p>
</nav>

<script is:inline>
  (() => {
    const init = () => {
      document.querySelectorAll(".table-wrap").forEach((wrap) => {
        if (!(wrap instanceof HTMLElement) || wrap.dataset.shadowInit === "true") {
          return;
        }

        const bodyScroll = wrap.querySelector("[data-body-scroll]");
        const headScroll = wrap.querySelector("[data-head-scroll]");
        const expandToggle = wrap.querySelector("[data-expand-toggle]");
        const expandLabel = wrap.querySelector("[data-expand-label]");
        if (!(bodyScroll instanceof HTMLElement) || !(headScroll instanceof HTMLElement)) {
          return;
        }
        const hoverCells = Array.from(
          wrap.querySelectorAll("[data-hover-cell]")
        ).filter((cell) => cell instanceof HTMLElement);

        const update = () => {
          headScroll.scrollLeft = bodyScroll.scrollLeft;
          wrap.dataset.scrolledX = bodyScroll.scrollLeft > 2 ? "true" : "false";
          wrap.dataset.scrolledY =
            wrap.getBoundingClientRect().top < 0 ? "true" : "false";
        };

        const categoryNav = wrap.nextElementSibling;
        const categoryControls =
          categoryNav instanceof HTMLElement
            ? Array.from(categoryNav.querySelectorAll("[data-category]")).filter(
                (control) => control instanceof HTMLElement
              )
            : [];

        const categoryCheckboxes =
          categoryNav instanceof HTMLElement
            ? Array.from(categoryNav.querySelectorAll("[data-category-checkbox]")).filter(
                (cb) => cb instanceof HTMLInputElement
              )
            : [];

        const clearHover = () => {
          wrap.dataset.hovering = "false";
          hoverCells.forEach((cell) => {
            cell.classList.remove("is-highlight", "is-muted");
          });
        };

        const setHover = (target) => {
          if (!(target instanceof Element)) return;
          const active = target.closest("[data-hover-cell]");
          if (!(active instanceof HTMLElement)) {
            clearHover();
            return;
          }

          const row = active.dataset.rowKey;
          const col = active.dataset.colKey;
          wrap.dataset.hovering = "true";

          hoverCells.forEach((cell) => {
            const rowMatches = row && cell.dataset.rowKey === row;
            const colMatches = col && cell.dataset.colKey === col;
            const highlighted = Boolean(rowMatches || colMatches);
            cell.classList.toggle("is-highlight", highlighted);
            cell.classList.toggle("is-muted", !highlighted);
          });
        };

        const setCategoryHover = (category) => {
          wrap.dataset.hovering = "true";

          hoverCells.forEach((cell) => {
            const highlighted =
              cell.dataset.rowGroup === category || cell.dataset.colGroup === category;
            cell.classList.toggle("is-highlight", highlighted);
            cell.classList.toggle("is-muted", !highlighted);
          });

          scrollToCategory(category);
        };

        const scrollToCategory = (category) => {
          const col = wrap.querySelector(`[data-col-group="${category}"]`);
          const row = wrap.querySelector(`[data-row-group="${category}"]`);
          if (col instanceof HTMLElement) {
            bodyScroll.scrollTo({
              left: Math.max(0, col.offsetLeft - bodyScroll.clientWidth * 0.08),
              behavior: "smooth",
            });
          }

          if (row instanceof HTMLElement) {
            const stickyOffset =
              wrap.querySelector(".table-head-stick") instanceof HTMLElement
                ? wrap.querySelector(".table-head-stick").getBoundingClientRect().height
                : 0;
            window.scrollTo({
              top: window.scrollY + row.getBoundingClientRect().top - stickyOffset - 4,
              behavior: "smooth",
            });
          }
        };

        const toggleExpanded = () => {
          const isExpanded = wrap.dataset.expanded === "true";
          wrap.dataset.expanded = isExpanded ? "false" : "true";
          if (expandToggle instanceof HTMLButtonElement) {
            expandToggle.setAttribute("aria-pressed", isExpanded ? "false" : "true");
          }
          if (expandLabel instanceof HTMLElement) {
            expandLabel.textContent = isExpanded ? "Show all" : "Top 10";
          }
        };

        const updateCategoryVisibility = () => {
          const hiddenCategories = new Set();
          categoryCheckboxes.forEach((cb) => {
            if (!cb.checked) {
              hiddenCategories.add(cb.dataset.categoryCheckbox);
            }
          });
          wrap.dataset.hiddenCategories = Array.from(hiddenCategories).join(",");
          hoverCells.forEach((cell) => {
            const rowGroup = cell.dataset.rowGroup;
            const colGroup = cell.dataset.colGroup;
            const hidden = hiddenCategories.has(rowGroup) || hiddenCategories.has(colGroup);
            cell.classList.toggle("is-category-hidden", hidden);
          });
          const rows = wrap.querySelectorAll("[data-row-substance]");
          rows.forEach((row) => {
            if (!(row instanceof HTMLElement)) return;
            const rowHead = row.querySelector("[data-row-group]");
            if (!(rowHead instanceof HTMLElement)) return;
            const rowGroup = rowHead.dataset.rowGroup;
            const hidden = hiddenCategories.has(rowGroup);
            row.classList.toggle("is-row-hidden", hidden);
          });
          const colHeads = wrap.querySelectorAll("[data-col-key][data-col-group]");
          colHeads.forEach((col) => {
            if (!(col instanceof HTMLElement)) return;
            const colGroup = col.dataset.colGroup;
            const hidden = hiddenCategories.has(colGroup);
            col.classList.toggle("is-col-hidden", hidden);
          });
        };

        wrap.dataset.shadowInit = "true";
        wrap.dataset.expanded = "false";
        update();

        bodyScroll.addEventListener("scroll", update, { passive: true });
        wrap.addEventListener("pointerover", (event) => setHover(event.target));
        wrap.addEventListener("pointerleave", clearHover);
        wrap.addEventListener("focusin", (event) => setHover(event.target));
        wrap.addEventListener("focusout", clearHover);

        if (expandToggle instanceof HTMLButtonElement) {
          expandToggle.addEventListener("click", toggleExpanded);
        }

        categoryCheckboxes.forEach((cb) => {
          cb.addEventListener("change", updateCategoryVisibility);
        });

        categoryControls.forEach((control) => {
          control.addEventListener("pointerover", () => {
            const checkbox = control.querySelector("[data-category-checkbox]");
            if (checkbox instanceof HTMLInputElement && !checkbox.checked) return;
            setCategoryHover(control.dataset.category);
          });
          control.addEventListener("pointerleave", clearHover);
          control.addEventListener("focus", () => {
            const checkbox = control.querySelector("[data-category-checkbox]");
            if (checkbox instanceof HTMLInputElement && !checkbox.checked) return;
            setCategoryHover(control.dataset.category);
          });
          control.addEventListener("blur", clearHover);
        });
        window.addEventListener("scroll", update, { passive: true });
        window.addEventListener("resize", update, { passive: true });
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, { once: true });
    } else {
      init();
    }
  })();
</script>

<style>
  .table-wrap {
    --cell-size: clamp(28px, 4.2vw, 52px);
    --cell-gap: 2px;
    --row-head-size: calc(var(--cell-size) + var(--cell-gap));
    --ink: var(--color-ink);
    --exit-duration: 350ms;
    --enter-duration: 0ms;
    width: 100%;
    padding: 0;
    position: relative;
  }

  .table-head-stick {
    position: sticky;
    top: 0;
    z-index: 8;
    display: grid;
    grid-template-columns: var(--row-head-size) 1fr;
    align-items: stretch;
    background-color: var(--ink);
  }

  .table-head-stick::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 14px;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.28), transparent);
    opacity: 0;
    transition: opacity 140ms ease;
  }

  .table-wrap[data-scrolled-y="true"] .table-head-stick::after {
    opacity: 1;
  }

  .table-head-scroll {
    overflow: hidden;
    background-color: var(--ink);
  }

  .shadow-left {
    position: absolute;
    top: calc(var(--cell-size) + var(--cell-gap) * 2);
    left: var(--row-head-size);
    height: calc((var(--cell-size) + var(--cell-gap)) * 25);
    width: 14px;
    pointer-events: none;
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.28), transparent);
    opacity: 0;
    transition: opacity 140ms ease;
    z-index: 7;
  }

  .table-wrap[data-scrolled-x="true"] .shadow-left {
    opacity: 1;
  }

  .table-scroll {
    position: relative;
    width: 100%;
    overflow-x: auto;
    overflow-y: visible;
    overscroll-behavior-x: contain;
    overscroll-behavior-y: auto;
    touch-action: pan-x pan-y;
    background-color: var(--ink);
    -webkit-overflow-scrolling: touch;
  }

  .table-scroll:focus-visible {
    outline: none;
  }

  .combos-table {
    border-collapse: separate;
    border-spacing: var(--cell-gap);
    background-color: var(--ink);
    font-size: clamp(10px, 1.1vw, 13px);
    table-layout: fixed;
    width: max-content;
    min-width: 100%;
  }

  .combos-table th,
  .combos-table td {
    padding: 0;
    margin: 0;
    width: var(--cell-size);
    height: var(--cell-size);
    min-width: var(--cell-size);
    max-width: var(--cell-size);
    box-sizing: border-box;
    overflow: hidden;
  }

  [data-hover-cell] {
    transition:
      filter var(--exit-duration) ease,
      opacity var(--exit-duration) ease;
    will-change: filter, opacity;
  }

  .table-wrap[data-hovering="true"] [data-hover-cell] {
    transition:
      filter var(--enter-duration) ease,
      opacity var(--enter-duration) ease;
  }

  .table-wrap[data-hovering="true"] [data-hover-cell].is-muted {
    filter: saturate(0.25) brightness(0.75);
    opacity: 0.7;
  }

  .table-wrap[data-hovering="true"] [data-hover-cell].is-highlight {
    filter: saturate(1.12) brightness(1.1);
    opacity: 1;
  }

  .corner {
    background-color: var(--ink);
    width: var(--row-head-size);
    min-width: var(--row-head-size);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .expand-toggle {
    appearance: none;
    border: 0;
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-fg-mute);
    font: inherit;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 4px 6px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 120ms ease, color 120ms ease;
  }

  .expand-toggle:hover {
    background: rgba(255, 255, 255, 0.14);
    color: var(--color-fg);
  }

  .expand-toggle[aria-pressed="true"] {
    background: rgba(255, 255, 255, 0.16);
    color: var(--color-fg);
  }

  .table-wrap[data-expanded="false"] tr[data-is-top="false"] {
    display: none;
  }

  .table-wrap[data-expanded="false"] th.col-head[data-is-top="false"] {
    display: none;
  }

  .table-wrap[data-expanded="false"] td[data-is-top-row="false"],
  .table-wrap[data-expanded="false"] td[data-is-top-col="false"],
  .table-wrap[data-expanded="false"] th.diag[data-is-top-row="false"],
  .table-wrap[data-expanded="false"] th.diag[data-is-top-col="false"] {
    display: none;
  }

  .is-row-hidden {
    display: none !important;
  }

  .is-col-hidden {
    display: none !important;
  }

  .col-head {
    height: var(--cell-size);
    min-height: var(--cell-size);
    width: var(--cell-size);
    min-width: var(--cell-size);
    padding: 0;
  }

  .label-link {
    display: flex;
    width: var(--cell-size);
    height: var(--cell-size);
    align-items: center;
    justify-content: center;
    padding: 2px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    box-sizing: border-box;
  }

  .col-head .label-text,
  .row-head .label-text {
    display: inline-block;
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.02em;
    line-height: 1.05;
    text-align: center;
    white-space: normal;
    overflow-wrap: anywhere;
    max-width: 100%;
  }

  .row-head {
    position: sticky;
    left: 0;
    z-index: 3;
    width: var(--cell-size);
    min-width: var(--cell-size);
    background-clip: padding-box;
    box-shadow: inset -1px 0 0 rgba(255, 255, 255, 0.04);
  }

  .row-head .row-link {
    font-size: 10px;
  }

  .row-head .row-link:hover,
  .col-head .label-link:hover {
    filter: brightness(1.2);
  }

  .diag .diag-link {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    padding: 0;
    text-decoration: none;
    color: inherit;
  }

  .diag .label-text {
    display: inline-block;
    transform: rotate(-45deg);
    font-weight: 600;
    font-size: 10px;
    white-space: nowrap;
    line-height: 1;
    opacity: 0.9;
  }

  .label-xs .label-text {
    font-size: 6px;
    letter-spacing: 0;
  }

  .label-sm .label-text {
    font-size: 7px;
  }

  .label-md .label-text {
    font-size: 8px;
  }

  .cell-td {
    padding: 0;
    background-color: var(--ink);
  }

  .category-nav {
    position: fixed;
    left: 50%;
    bottom: 0;
    z-index: 30;
    width: min(100%, 1600px);
    padding: 8px 0 max(6px, env(safe-area-inset-bottom));
    background-color: color-mix(in oklab, var(--color-ink), transparent 6%);
    box-shadow: 0 -14px 24px rgba(0, 0, 0, 0.28);
    transform: translateX(-50%);
  }

  .category-strip {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    width: 100%;
    overflow: hidden;
  }

  .category-card {
    border: 0;
    border-radius: 0;
    min-height: 118px;
    padding: clamp(10px, 1.2vw, 16px) clamp(8px, 1vw, 14px);
    color: #080808;
    cursor: pointer;
    font: inherit;
    text-align: left;
    background-image: none;
    transition:
      filter 350ms ease,
      opacity 350ms ease,
      transform 120ms ease;
  }

  .category-card:hover,
  .category-card:focus-within {
    filter: brightness(1.05) saturate(1.05);
    transition-duration: 0ms;
  }

  .category-card:active {
    transform: translateY(1px);
  }

  .category-card:has(.category-checkbox:not(:checked)) {
    filter: saturate(0.3) brightness(0.7);
    opacity: 0.6;
  }

  .category-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    margin-bottom: 8px;
  }

  .category-checkbox {
    appearance: none;
    width: 14px;
    height: 14px;
    border: 2px solid rgba(255, 255, 255, 0.7);
    border-radius: 3px;
    background: transparent;
    cursor: pointer;
    flex-shrink: 0;
    position: relative;
    transition: background 120ms ease, border-color 120ms ease;
  }

  .category-checkbox:checked {
    background: rgba(255, 255, 255, 0.95);
    border-color: rgba(255, 255, 255, 0.95);
  }

  .category-checkbox:checked::after {
    content: "";
    position: absolute;
    top: 1px;
    left: 4px;
    width: 3px;
    height: 6px;
    border: solid #080808;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .category-checkbox:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .category-heading {
    display: inline;
    margin: 0;
    color: #fff;
    font-size: clamp(13px, 0.95vw, 16px);
    font-weight: 800;
    line-height: 1.05;
  }

  .category-card p {
    margin: 0;
    font-size: clamp(10px, 0.72vw, 12px);
    line-height: 1.22;
  }

  .category-credit {
    margin: 5px 8px 0;
    color: var(--color-fg-mute);
    font-size: 10px;
    line-height: 1.3;
    text-align: left;
  }

  .category-credit a {
    color: var(--color-fg);
    text-underline-offset: 3px;
  }

  @media (max-width: 640px) {
    .table-wrap {
      --cell-size: 45px;
    }

    .expand-toggle {
      font-size: 7px;
      padding: 3px 5px;
    }

    .category-strip {
      display: flex;
      gap: 2px;
      margin-inline: calc(var(--cell-gap) * -1);
      padding: 0 20% 2px 0;
      overflow-x: auto;
      overscroll-behavior-x: contain;
      scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch;
    }

    .category-card {
      flex: 0 0 80%;
      min-height: 122px;
      padding: 14px 12px;
      scroll-snap-align: start;
    }

    .category-heading {
      font-size: 15px;
    }

    .category-checkbox {
      width: 16px;
      height: 16px;
    }

