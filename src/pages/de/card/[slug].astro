---
import SubstanceCard from "../../../components/SubstanceCard.astro";
import { getColumnBySlug } from "../../../data/config";

export const prerender = true;

export async function getStaticPaths() {
  const { getColumns } = await import("../../../data/config");
  return getColumns("de").map((col) => ({ params: { slug: col.slug } }));
}

const { slug } = Astro.params;
if (!slug) {
  return new Response("Not found", { status: 404 });
}

const col = getColumnBySlug("de", slug);
if (!col) return new Response("Not found", { status: 404 });
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <title>card</title>
  </head>
  <body>
    <div data-card-fragment>
      <SubstanceCard substanceKey={col.key} locale="de" />
    </div>
  </body>
</html>
