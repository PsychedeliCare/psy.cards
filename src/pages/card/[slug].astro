---
import SubstanceCard from "../../components/SubstanceCard.astro";
import { getColumnBySlug } from "../../data/config";
import type { Locale } from "../../i18n/locales";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;

export const prerender = true;

export async function getStaticPaths() {
  const { getColumns } = await import("../../data/config");
  return getColumns("en").map((col) => ({ params: { slug: col.slug } }));
}

const { slug } = Astro.params;
if (!slug) {
  return new Response("Not found", { status: 404 });
}

const col = getColumnBySlug(locale, slug);
if (!col) return new Response("Not found", { status: 404 });
const substanceKey = col.key;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <title>card</title>
  </head>
  <body>
    <div data-card-fragment>
      <SubstanceCard substanceKey={substanceKey} locale={locale} />
    </div>
  </body>
</html>
