---
import Icon from "./Icon.astro";
import { getInteraction } from "../data/combos";
import { getColumnByKey, sortPair } from "../data/config";
import { getSubstanceStructure } from "../data/substances";
import { keyToSlug } from "../data/slug";
import { localePath } from "../i18n/locales";
import MoleculeFigure from "./MoleculeFigure.astro";
import CardContribute from "./CardContribute.astro";
import SmilesCitation from "./SmilesCitation.astro";
import type { Locale } from "../i18n/locales";
import { getUiMessages } from "../i18n/load-locale";
import { t, tFormat } from "../i18n/ui";

interface Props {
  keyA: string;
  keyB: string;
  locale?: Locale;
}

const { keyA: rawA, keyB: rawB, locale = "en" } = Astro.props;
const ui = getUiMessages(locale);
const substanceBase = localePath(locale, "/");
const [keyA, keyB] = sortPair(locale, rawA, rawB);

const colA = getColumnByKey(locale, keyA);
const colB = getColumnByKey(locale, keyB);
const labelA = colA?.label ?? keyA;
const labelB = colB?.label ?? keyB;

const { definition, note, sources } = getInteraction(keyA, keyB, locale);
const hasStructure =
  Boolean(getSubstanceStructure(keyA)) || Boolean(getSubstanceStructure(keyB));
const statusTooltipId = `status-tooltip-${keyA}-${keyB}`;
---

<article
  class={`combo-card status-${definition.statusKey}`}
  data-card-type="combo"
  data-combo-keys={`${keyA}|${keyB}`}
>
  <MoleculeFigure substanceKeys={[keyA, keyB]} />
  <header class="card-header">
    <div class="status-bar status-surface" aria-hidden="true"></div>
    <div class="heading">
      <div class="pair">
        <a
          href={`${substanceBase}${keyToSlug(keyA)}`}
          class={`chip group-${colA?.group ?? "unknown"} category-surface cell-text`}
          data-substance={`${substanceBase}${keyToSlug(keyA)}`}
        >
          {labelA}
        </a>
        <span class="plus" aria-hidden="true">+</span>
        <a
          href={`${substanceBase}${keyToSlug(keyB)}`}
          class={`chip group-${colB?.group ?? "unknown"} category-surface cell-text`}
          data-substance={`${substanceBase}${keyToSlug(keyB)}`}
        >
          {labelB}
        </a>
      </div>
      <div class="status-line">
        <span class="status-tip">
          <button
            type="button"
            class="status-chip status-surface cell-text"
            title={definition.definition}
            aria-describedby={statusTooltipId}
          >
            <Icon name={definition.icon} size="0.95em" />
            <span>{definition.label}</span>
          </button>
          <span class="status-tooltip" id={statusTooltipId} role="tooltip">
            {definition.definition}
          </span>
        </span>
      </div>
    </div>
  </header>

  <p class="definition">{definition.definition}</p>

  {
    note && (
      <section class="note">
        <h3>{t(locale, ui, "comboCard.noteOnPair")}</h3>
        <p>{note}</p>
      </section>
    )
  }

  {
    sources && sources.length > 0 && (
      <section class="sources">
        <h3>{t(locale, ui, "comboCard.sources")}</h3>
        <ul>
          {sources.map((s) => (
            <li>
              <a href={s.url} target="_blank" rel="noreferrer noopener">
                {s.title}
              </a>
              {s.author && <span class="author"> — {s.author}</span>}
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="actions">
    <a class="action-link" href={`${substanceBase}${keyToSlug(keyA)}`} data-substance={`${substanceBase}${keyToSlug(keyA)}`}>
      {tFormat(locale, ui, "comboCard.about", { label: labelA })}
    </a>
    <a class="action-link" href={`${substanceBase}${keyToSlug(keyB)}`} data-substance={`${substanceBase}${keyToSlug(keyB)}`}>
      {tFormat(locale, ui, "comboCard.about", { label: labelB })}
    </a>
  </section>

  {hasStructure && <SmilesCitation locale={locale} />}

  <CardContribute locale={locale} />
</article>
