---
import Layout from "../components/Layout.astro";
import Footer from "../components/Footer.astro";
import type { Locale } from "../i18n/locales";
import { getUiMessages } from "../i18n/load-locale";
import { t } from "../i18n/ui";
import { localePath } from "../i18n/locales";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const ui = getUiMessages(locale);
---

<Layout
  locale={locale}
  title={t(locale, ui, "meta.siteTitle")}
  description={t(locale, ui, "meta.landingDescription")}
>
  <main class="landing">
    <section class="hero">
      <p class="eyebrow">{t(locale, ui, "landing.eyebrow")}</p>
      <h1>{t(locale, ui, "landing.title")}</h1>
      <p class="lede">{t(locale, ui, "landing.lede")}</p>
      <p class="cta">
        <a href={localePath(locale, "/combos")} class="primary">
          {t(locale, ui, "landing.cta")}
        </a>
      </p>
    </section>

    <section class="about">
      <p>{t(locale, ui, "landing.about")}</p>
    </section>
  </main>

  <Footer locale={locale} variant="narrow" />
</Layout>

<style>
  .landing {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 20px 80px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .hero {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .eyebrow {
    margin: 0;
    font-size: 12px;
    color: var(--color-fg-mute);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    max-width: 14ch;
  }

  .lede {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-fg);
    max-width: 52ch;
  }

  .cta {
    margin: 6px 0 0;
  }

  .primary {
    display: inline-block;
    padding: 10px 18px;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.01em;
    color: var(--color-ink);
    background-color: var(--color-safe);
    text-decoration: none;
    transition:
      filter 140ms ease,
      transform 140ms ease;
  }

  .primary:hover {
    filter: brightness(1.1);
  }

  .about p {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--color-fg);
    max-width: 58ch;
  }
</style>
