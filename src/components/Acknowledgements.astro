---
import type { Locale } from "../i18n/locales";
import { getUiMessages } from "../i18n/load-locale";
import { t, tFormat } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const ui = getUiMessages(locale);
---

<section class="acknowledgements" aria-label={t(locale, ui, "acknowledgements.ariaLabel")}>
  <h2 class="acknowledgements__title">{t(locale, ui, "acknowledgements.title")}</h2>
  <ul class="acknowledgements__list">
    <li
      set:html={tFormat(locale, ui, "acknowledgements.drugsWheelCredit", {
        link: `<a href="https://www.thedrugswheel.com/" target="_blank" rel="noreferrer noopener">${t(locale, ui, "acknowledgements.drugsWheel")}</a>`,
      })}
    />
  </ul>
</section>

<style>
  .acknowledgements {
    max-width: 860px;
    margin: 0 auto;
    padding: 28px 16px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .acknowledgements__title {
    margin: 0 0 12px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-fg-mute);
  }

  .acknowledgements__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .acknowledgements__list li {
    margin: 0;
    font-size: 13px;
    line-height: 1.55;
    color: var(--color-fg-mute);
  }

  .acknowledgements__list :global(a) {
    color: var(--color-fg);
    text-decoration: none;
    border-bottom: 1px solid rgba(166, 166, 170, 0.28);
    transition:
      border-color 0.15s ease,
      color 0.15s ease;
  }

  .acknowledgements__list :global(a:hover),
  .acknowledgements__list :global(a:focus-visible) {
    color: var(--color-fg);
    border-color: rgba(245, 245, 245, 0.42);
  }
</style>
