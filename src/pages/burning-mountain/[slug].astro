---
import BurningMountainPage from "../burning-mountain.astro";
import { getColumns } from "../../data/config";

export const prerender = true;

export function getStaticPaths() {
  return getColumns("en").map((column) => ({
    params: { slug: column.slug },
    props: { modalSubstanceKey: column.key },
  }));
}

const { modalSubstanceKey } = Astro.props as { modalSubstanceKey: string };
---

<BurningMountainPage locale="en" modalSubstanceKey={modalSubstanceKey} />
