{
	"compatibility_date": "2026-04-23",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "psy-cards",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"routes": [
		{
			"pattern": "psy.cards",
			"custom_domain": true
		},
		{
			"pattern": "www.psy.cards",
			"custom_domain": true
		}
	],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}
