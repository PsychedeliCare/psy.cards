---
import ComboCell from "./ComboCell.astro";
import { columns } from "../data/config";
---

<section class="table-wrap" aria-label="Drug combinations">
  <div class="table-scroll" role="region" tabindex="0">
    <table class="combos-table" role="grid">
      <thead>
        <tr>
          <th scope="col" class="corner" aria-label="Combinations"></th>
          {
            columns.map((col) => (
              <th
                scope="col"
                class={`col-head group-${col.group} category-surface cell-text`}
                data-substance-slug={col.slug}
              >
                <a
                  href={`/${col.slug}`}
                  class="label-link"
                  data-substance={`/${col.slug}`}
                >
                  <span class="label-text">{col.label}</span>
                </a>
              </th>
            ))
          }
        </tr>
      </thead>
      <tbody>
        {
          columns.map((row) => (
            <tr>
              <th
                scope="row"
                class={`row-head group-${row.group} category-surface cell-text`}
                data-substance-slug={row.slug}
              >
                <a
                  href={`/${row.slug}`}
                  class="label-link row-link"
                  data-substance={`/${row.slug}`}
                >
                  {row.label}
                </a>
              </th>
              {columns.map((col) =>
                row.key === col.key ? (
                  <th
                    scope="col"
                    class={`diag group-${row.group} category-surface cell-text`}
                  >
                    <a
                      href={`/${row.slug}`}
                      class="label-link diag-link"
                      data-substance={`/${row.slug}`}
                    >
                      <span class="label-text">{row.label}</span>
                    </a>
                  </th>
                ) : (
                  <td class="cell-td">
                    <ComboCell
                      rowKey={row.key}
                      colKey={col.key}
                      rowLabel={row.label}
                      colLabel={col.label}
                    />
                  </td>
                )
              )}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>

<style>
  .table-wrap {
    --cell-size: clamp(28px, 4.2vw, 52px);
    --row-head-w: clamp(92px, 20vw, 160px);
    --col-head-h: clamp(108px, 22vw, 180px);
    --ink: var(--color-ink);
    --ink-2: var(--color-ink-2);
    width: 100%;
    padding: 0;
  }

  .table-scroll {
    width: 100%;
    overflow-x: auto;
    overflow-y: visible;
    overscroll-behavior-x: contain;
    overscroll-behavior-y: auto;
    touch-action: pan-x pan-y;
    background-color: var(--ink);
    -webkit-overflow-scrolling: touch;
  }

  .table-scroll:focus-visible {
    outline: none;
  }

  .combos-table {
    border-collapse: separate;
    border-spacing: 2px;
    background-color: var(--ink);
    font-size: clamp(10px, 1.1vw, 13px);
    table-layout: fixed;
    width: max-content;
    min-width: 100%;
  }

  .combos-table th,
  .combos-table td {
    padding: 0;
    margin: 0;
    width: var(--cell-size);
    height: var(--cell-size);
    box-sizing: border-box;
  }

  .corner {
    position: sticky;
    top: 0;
    left: 0;
    z-index: 4;
    background-color: var(--ink);
    width: var(--row-head-w);
    height: var(--col-head-h);
    min-width: var(--row-head-w);
  }

  .col-head {
    position: sticky;
    top: 0;
    z-index: 2;
    height: var(--col-head-h);
    min-height: var(--col-head-h);
    vertical-align: bottom;
    width: var(--cell-size);
    min-width: var(--cell-size);
    padding: 0;
  }

  .col-head .label-link {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: flex-end;
    justify-content: center;
    padding: 6px 0 8px;
    text-decoration: none;
    color: inherit;
  }

  .col-head .label-text {
    display: inline-block;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-weight: 600;
    font-size: clamp(10px, 1vw, 13px);
    letter-spacing: 0.02em;
    white-space: nowrap;
    padding: 4px 0;
    line-height: 1;
  }

  .row-head {
    position: sticky;
    left: 0;
    z-index: 2;
    width: var(--row-head-w);
    min-width: var(--row-head-w);
    text-align: left;
  }

  .row-head .row-link {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: flex-start;
    padding: 0 10px;
    font-weight: 600;
    font-size: clamp(11px, 1vw, 14px);
    letter-spacing: 0.01em;
    white-space: nowrap;
    text-decoration: none;
    color: inherit;
  }

  .row-head .row-link:hover,
  .col-head .label-link:hover {
    filter: brightness(1.2);
  }

  .diag .diag-link {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    padding: 0;
    text-decoration: none;
    color: inherit;
  }

  .diag .label-text {
    display: inline-block;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-weight: 600;
    font-size: clamp(9px, 0.95vw, 12px);
    white-space: nowrap;
    line-height: 1;
    opacity: 0.9;
  }

  .cell-td {
    padding: 0;
    background-color: var(--ink);
  }

  @media (max-width: 640px) {
    .table-wrap {
      --cell-size: 30px;
      --row-head-w: 92px;
      --col-head-h: 104px;
    }
    .combos-table {
      font-size: 10px;
    }
    .row-head .row-link {
      padding: 0 8px;
      font-size: 11px;
    }
  }
</style>
