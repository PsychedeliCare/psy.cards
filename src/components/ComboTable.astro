---
import CategoryNav from "./CategoryNav.astro";
import ComboCell from "./ComboCell.astro";
import { columns } from "../data/config";

interface Props {
  comboRoute?: string;
  initialSubstanceSet?: "common" | "full";
}

const { comboRoute = "/combos", initialSubstanceSet = "full" } = Astro.props;

const commonSubstanceKeys = new Set([
  "amphetamines",
  "cocaine",
  "caffeine",
  "mdma",
  "lsd",
  "mushrooms",
  "ketamine",
  "alcohol",
  "ghb/gbl",
  "benzodiazepines",
  "cannabis",
]);

const isCommonSubstance = (key: string) => commonSubstanceKeys.has(key);

function getLabelSizeClass(label: string) {
  if (label.length >= 11) return "label-xs";
  if (label.length >= 8) return "label-sm";
  return "label-md";
}
---

<section
  class="table-wrap"
  aria-label="Drug combinations"
  data-medication="false"
  data-hover-enabled="true"
  data-substance-set={initialSubstanceSet}
>
  <div class="shadow-left" aria-hidden="true" data-table-shadow></div>
  <div class="table-head-stick">
    <div class="corner" aria-hidden="true"></div>
    <div class="table-head-scroll" data-head-scroll>
      <table class="combos-table combos-table--head" role="presentation">
        <thead>
          <tr>
            {
              columns.map((col) => (
                <th
                  scope="col"
                  class={`col-head group-${col.group} category-surface cell-text ${getLabelSizeClass(col.label)}`}
                  data-substance-slug={col.slug}
                  data-col-key={col.key}
                  data-col-group={col.group}
                  data-col-common={String(isCommonSubstance(col.key))}
                  data-hover-cell
                >
                  <a
                    href={`/${col.slug}`}
                    class="label-link col-link"
                    data-substance={`/${col.slug}`}
                  >
                    <span class="label-text">{col.label}</span>
                  </a>
                </th>
              ))
            }
          </tr>
        </thead>
      </table>
    </div>
  </div>

  <div class="table-scroll" role="region" tabindex="0" data-body-scroll>
    <table class="combos-table combos-table--body" role="grid">
      <tbody>
        {
          columns.map((row) => (
            <tr data-row-substance={row.key} data-row-common={String(isCommonSubstance(row.key))}>
              <th
                scope="row"
                class={`row-head group-${row.group} category-surface cell-text ${getLabelSizeClass(row.label)}`}
                data-substance-slug={row.slug}
                data-row-key={row.key}
                data-row-group={row.group}
                data-row-common={String(isCommonSubstance(row.key))}
                data-hover-cell
              >
                <a
                  href={`/${row.slug}`}
                  class="label-link row-link"
                  data-substance={`/${row.slug}`}
                >
                  <span class="label-text">{row.label}</span>
                </a>
              </th>
              {columns.map((col) =>
                row.key === col.key ? (
                  <th
                    scope="col"
                    class={`diag group-${row.group} category-surface cell-text ${getLabelSizeClass(row.label)}`}
                    data-row-key={row.key}
                    data-col-key={col.key}
                    data-row-group={row.group}
                    data-col-group={col.group}
                    data-row-common={String(isCommonSubstance(row.key))}
                    data-col-common={String(isCommonSubstance(col.key))}
                    data-hover-cell
                  >
                    <a
                      href={`/${row.slug}`}
                      class="label-link diag-link"
                      data-substance={`/${row.slug}`}
                    >
                      <span class="label-text">{row.label}</span>
                    </a>
                  </th>
                ) : (
                  <td
                    class="cell-td"
                    data-row-key={row.key}
                    data-col-key={col.key}
                    data-row-group={row.group}
                    data-col-group={col.group}
                    data-row-common={String(isCommonSubstance(row.key))}
                    data-col-common={String(isCommonSubstance(col.key))}
                    data-hover-cell
                  >
                    <ComboCell
                      rowKey={row.key}
                      colKey={col.key}
                      rowLabel={row.label}
                      colLabel={col.label}
                      comboRoute={comboRoute}
                    />
                  </td>
                )
              )}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>

<CategoryNav initialSubstanceSet={initialSubstanceSet} />

<script is:inline>
  (() => {
    const init = () => {
      document.querySelectorAll(".table-wrap").forEach((wrap) => {
        if (!(wrap instanceof HTMLElement) || wrap.dataset.shadowInit === "true") {
          return;
        }

        const bodyScroll = wrap.querySelector("[data-body-scroll]");
        const headScroll = wrap.querySelector("[data-head-scroll]");
        if (!(bodyScroll instanceof HTMLElement) || !(headScroll instanceof HTMLElement)) {
          return;
        }
        const hoverCells = Array.from(
          wrap.querySelectorAll("[data-hover-cell]")
        ).filter((cell) => cell instanceof HTMLElement);

        const update = () => {
          headScroll.scrollLeft = bodyScroll.scrollLeft;
          wrap.dataset.scrolledX = bodyScroll.scrollLeft > 2 ? "true" : "false";
          wrap.dataset.scrolledY =
            wrap.getBoundingClientRect().top < 0 ? "true" : "false";
        };

        const categoryNav = wrap.nextElementSibling;
        const categoryControls =
          categoryNav instanceof HTMLElement
            ? Array.from(categoryNav.querySelectorAll("[data-category]")).filter(
                (control) => control instanceof HTMLElement
              )
            : [];

        const categoryCheckboxes =
          categoryNav instanceof HTMLElement
            ? Array.from(categoryNav.querySelectorAll("[data-category-checkbox]")).filter(
                (cb) => cb instanceof HTMLInputElement
              )
            : [];

        const clearHover = () => {
          wrap.dataset.hovering = "false";
          hoverCells.forEach((cell) => {
            cell.classList.remove("is-highlight", "is-muted");
          });
        };

        const setHover = (target) => {
          if (wrap.dataset.hoverEnabled === "false") return;
          if (!(target instanceof Element)) return;
          const active = target.closest("[data-hover-cell]");
          if (!(active instanceof HTMLElement)) {
            clearHover();
            return;
          }

          const row = active.dataset.rowKey;
          const col = active.dataset.colKey;
          wrap.dataset.hovering = "true";

          hoverCells.forEach((cell) => {
            const rowMatches = row && cell.dataset.rowKey === row;
            const colMatches = col && cell.dataset.colKey === col;
            const highlighted = Boolean(rowMatches || colMatches);
            cell.classList.toggle("is-highlight", highlighted);
            cell.classList.toggle("is-muted", !highlighted);
          });
        };

        const setCategoryHover = (category) => {
          if (wrap.dataset.hoverEnabled !== "false") {
            wrap.dataset.hovering = "true";

            hoverCells.forEach((cell) => {
              const highlighted =
                cell.dataset.rowGroup === category || cell.dataset.colGroup === category;
              cell.classList.toggle("is-highlight", highlighted);
              cell.classList.toggle("is-muted", !highlighted);
            });
          }

          scrollToCategory(category);
        };

        const scrollToCategory = (category) => {
          const col = wrap.querySelector(`[data-col-group="${category}"]`);
          const row = wrap.querySelector(`[data-row-group="${category}"]`);
          if (col instanceof HTMLElement) {
            bodyScroll.scrollTo({
              left: Math.max(0, col.offsetLeft - bodyScroll.clientWidth * 0.08),
              behavior: "smooth",
            });
          }

          if (row instanceof HTMLElement) {
            const stickyOffset =
              wrap.querySelector(".table-head-stick") instanceof HTMLElement
                ? wrap.querySelector(".table-head-stick").getBoundingClientRect().height
                : 0;
            window.scrollTo({
              top: window.scrollY + row.getBoundingClientRect().top - stickyOffset - 4,
              behavior: "smooth",
            });
          }
        };

        const viewButtons =
          categoryNav instanceof HTMLElement
            ? Array.from(categoryNav.querySelectorAll("[data-view]")).filter(
                (b) => b instanceof HTMLButtonElement
              )
            : [];

        const medicationToggle =
          categoryNav instanceof HTMLElement
            ? categoryNav.querySelector("[data-medication-toggle]")
            : null;

        const highlightToggle =
          categoryNav instanceof HTMLElement
            ? categoryNav.querySelector("[data-highlight-toggle]")
            : null;

        const setView = (view) => {
          const substanceSet = view === "full" ? "full" : "common";
          wrap.dataset.substanceSet = substanceSet;
          viewButtons.forEach((btn) => {
            const active = btn.dataset.view === substanceSet;
            btn.classList.toggle("is-active", active);
            btn.setAttribute("aria-pressed", active ? "true" : "false");
          });
          bodyScroll.scrollLeft = 0;
          update();
        };

        const setMedication = (visible) => {
          wrap.dataset.medication = visible ? "true" : "false";
        };

        const setHighlightEnabled = (enabled) => {
          wrap.dataset.hoverEnabled = enabled ? "true" : "false";
          if (!enabled) clearHover();
        };

        const updateCategoryVisibility = () => {
          const hiddenCategories = new Set();
          categoryCheckboxes.forEach((cb) => {
            if (!cb.checked) {
              hiddenCategories.add(cb.dataset.categoryCheckbox);
            }
          });
          wrap.dataset.hiddenCategories = Array.from(hiddenCategories).join(",");
          hoverCells.forEach((cell) => {
            const rowGroup = cell.dataset.rowGroup;
            const colGroup = cell.dataset.colGroup;
            const hidden = hiddenCategories.has(rowGroup) || hiddenCategories.has(colGroup);
            cell.classList.toggle("is-category-hidden", hidden);
          });
          const rows = wrap.querySelectorAll("[data-row-substance]");
          rows.forEach((row) => {
            if (!(row instanceof HTMLElement)) return;
            const rowHead = row.querySelector("[data-row-group]");
            if (!(rowHead instanceof HTMLElement)) return;
            const rowGroup = rowHead.dataset.rowGroup;
            const hidden = hiddenCategories.has(rowGroup);
            row.classList.toggle("is-row-hidden", hidden);
          });
          const colHeads = wrap.querySelectorAll("[data-col-key][data-col-group]");
          colHeads.forEach((col) => {
            if (!(col instanceof HTMLElement)) return;
            const colGroup = col.dataset.colGroup;
            const hidden = hiddenCategories.has(colGroup);
            col.classList.toggle("is-col-hidden", hidden);
          });
        };

        wrap.dataset.shadowInit = "true";
        setView(wrap.dataset.substanceSet === "common" ? "common" : "full");
        update();

        bodyScroll.addEventListener("scroll", update, { passive: true });
        wrap.addEventListener("combo-table:viewchange", () => {
          bodyScroll.scrollLeft = 0;
          update();
        });
        wrap.addEventListener("pointerover", (event) => setHover(event.target));
        wrap.addEventListener("pointerleave", clearHover);
        wrap.addEventListener("focusin", (event) => setHover(event.target));
        wrap.addEventListener("focusout", clearHover);

        viewButtons.forEach((btn) => {
          btn.addEventListener("click", () => {
            setView(btn.dataset.view);
          });
        });

        if (medicationToggle instanceof HTMLInputElement) {
          medicationToggle.addEventListener("change", () => {
            setMedication(medicationToggle.checked);
          });
          setMedication(medicationToggle.checked);
        }

        if (highlightToggle instanceof HTMLInputElement) {
          const isTouchDevice = window.matchMedia("(pointer: coarse)").matches;
          if (isTouchDevice) {
            highlightToggle.checked = false;
          }
          highlightToggle.addEventListener("change", () => {
            setHighlightEnabled(highlightToggle.checked);
          });
          setHighlightEnabled(highlightToggle.checked);
        }

        categoryCheckboxes.forEach((cb) => {
          cb.addEventListener("change", updateCategoryVisibility);
        });

        categoryControls.forEach((control) => {
          control.addEventListener("pointerover", () => {
            const checkbox = control.querySelector("[data-category-checkbox]");
            if (checkbox instanceof HTMLInputElement && !checkbox.checked) return;
            setCategoryHover(control.dataset.category);
          });
          control.addEventListener("pointerleave", clearHover);
          control.addEventListener("focus", () => {
            const checkbox = control.querySelector("[data-category-checkbox]");
            if (checkbox instanceof HTMLInputElement && !checkbox.checked) return;
            setCategoryHover(control.dataset.category);
          });
          control.addEventListener("blur", clearHover);
        });
        window.addEventListener("scroll", update, { passive: true });
        window.addEventListener("resize", update, { passive: true });
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, { once: true });
    } else {
      init();
    }
  })();
</script>

<style>
  .table-wrap {
    --cell-gap: 2px;
    --fluid-cell-size: calc((100cqi - 56px) / 27);
    --table-cell-size: max(64px, var(--fluid-cell-size));
    --cell-size: var(--table-cell-size);
    --row-head-size: calc(var(--table-cell-size) + var(--cell-gap));
    --ink: var(--color-ink);
    --exit-duration: 350ms;
    --enter-duration: 0ms;
    width: 100%;
    padding: 0;
    position: relative;
    container-type: inline-size;
  }

  .table-wrap[data-substance-set="common"] {
    --fluid-cell-size: calc((100cqi - 26px) / 12);
    --table-cell-size: max(72px, var(--fluid-cell-size));
  }

  .table-head-stick {
    position: sticky;
    top: 0;
    z-index: 8;
    display: grid;
    grid-template-columns: var(--row-head-size) 1fr;
    align-items: stretch;
    background-color: var(--ink);
  }

  .table-head-stick::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 14px;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.28), transparent);
    opacity: 0;
    transition: opacity 140ms ease;
  }

  .table-wrap[data-scrolled-y="true"] .table-head-stick::after {
    opacity: 1;
  }

  .table-head-scroll {
    overflow: hidden;
    background-color: var(--ink);
  }

  .shadow-left {
    position: absolute;
    top: calc(var(--table-cell-size) + var(--cell-gap) * 2);
    left: var(--row-head-size);
    height: calc((var(--table-cell-size) + var(--cell-gap)) * 25);
    width: 14px;
    pointer-events: none;
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.28), transparent);
    opacity: 0;
    transition: opacity 140ms ease;
    z-index: 7;
  }

  .table-wrap[data-scrolled-x="true"] .shadow-left {
    opacity: 1;
  }

  .table-scroll {
    position: relative;
    width: 100%;
    overflow-x: auto;
    overflow-y: visible;
    overscroll-behavior-x: contain;
    overscroll-behavior-y: auto;
    touch-action: pan-x pan-y;
    background-color: var(--ink);
    -webkit-overflow-scrolling: touch;
  }

  .table-scroll:focus-visible {
    outline: none;
  }

  .combos-table {
    border-collapse: separate;
    border-spacing: var(--cell-gap);
    background-color: var(--ink);
    font-size: clamp(15px, calc(var(--table-cell-size) * 0.2), 28px);
    table-layout: fixed;
    width: max-content;
    min-width: max-content;
  }

  .combos-table th,
  .combos-table td {
    padding: 0;
    margin: 0;
    width: var(--table-cell-size);
    height: var(--table-cell-size);
    min-width: var(--table-cell-size);
    max-width: var(--table-cell-size);
    box-sizing: border-box;
    overflow: hidden;
  }

  .table-wrap[data-substance-set="common"] [data-col-common="false"],
  .table-wrap[data-substance-set="common"] [data-row-common="false"] {
    display: none;
  }

  [data-hover-cell] {
    transition:
      filter var(--exit-duration) ease,
      opacity var(--exit-duration) ease;
    will-change: filter, opacity;
  }

  .table-wrap[data-hovering="true"] [data-hover-cell] {
    transition:
      filter var(--enter-duration) ease,
      opacity var(--enter-duration) ease;
  }

  .table-wrap[data-hovering="true"] [data-hover-cell].is-muted {
    filter: saturate(0.25) brightness(0.75);
    opacity: 0.7;
  }

  .table-wrap[data-hovering="true"] [data-hover-cell].is-highlight {
    filter: saturate(1.12) brightness(1.1);
    opacity: 1;
  }

  .corner {
    background-color: var(--ink);
    width: var(--row-head-size);
    min-width: var(--row-head-size);
    height: 100%;
  }

  .table-wrap[data-medication="false"] tr[data-row-substance="maois"],
  .table-wrap[data-medication="false"] tr[data-row-substance="ssris"] {
    display: none;
  }

  .table-wrap[data-medication="false"] th[data-col-key="maois"],
  .table-wrap[data-medication="false"] th[data-col-key="ssris"],
  .table-wrap[data-medication="false"] td[data-col-key="maois"],
  .table-wrap[data-medication="false"] td[data-col-key="ssris"] {
    display: none;
  }

  .is-row-hidden {
    display: none !important;
  }

  .is-col-hidden {
    display: none !important;
  }

  .col-head {
    height: var(--table-cell-size);
    min-height: var(--table-cell-size);
    width: var(--table-cell-size);
    min-width: var(--table-cell-size);
    padding: 0;
  }

  .label-link {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    padding: clamp(6px, calc(var(--table-cell-size) * 0.09), 14px);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    box-sizing: border-box;
  }

  .col-head .label-text,
  .row-head .label-text {
    display: inline-block;
    font-weight: 600;
    font-size: clamp(13px, calc(var(--table-cell-size) * 0.13), 18px);
    letter-spacing: 0.02em;
    line-height: 1.08;
    text-align: left;
    white-space: normal;
    overflow-wrap: break-word;
    max-width: 100%;
  }

  .col-head .label-link,
  .row-head .label-link {
    justify-content: flex-start;
  }

  .row-head {
    position: sticky;
    left: 0;
    z-index: 3;
    width: var(--table-cell-size);
    min-width: var(--table-cell-size);
    background-clip: padding-box;
    box-shadow: inset -1px 0 0 rgba(255, 255, 255, 0.04);
  }

  .row-head .row-link {
    font-size: inherit;
  }

  .row-head .row-link:hover,
  .col-head .label-link:hover {
    filter: brightness(1.2);
  }

  .diag .diag-link {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    padding: 0;
    text-decoration: none;
    color: inherit;
  }

  .diag .label-text {
    display: inline-block;
    transform: rotate(-45deg);
    font-weight: 600;
    font-size: clamp(11px, calc(var(--table-cell-size) * 0.115), 16px);
    white-space: nowrap;
    line-height: 1;
    opacity: 0.9;
  }

  .label-xs .label-text {
    font-size: clamp(10.5px, calc(var(--table-cell-size) * 0.09), 13.5px);
    letter-spacing: 0;
  }

  .label-sm .label-text {
    font-size: clamp(12px, calc(var(--table-cell-size) * 0.105), 15px);
  }

  .label-md .label-text {
    font-size: clamp(13px, calc(var(--table-cell-size) * 0.12), 16.5px);
  }

  .cell-td {
    padding: 0;
    background-color: var(--ink);
  }

  @media (max-width: 640px) {
    .table-wrap {
      --fluid-cell-size: 54px;
      --table-cell-size: 54px;
    }

    .table-wrap[data-substance-set="common"] {
      --fluid-cell-size: 58px;
      --table-cell-size: 58px;
    }

    .combos-table {
      font-size: 17px;
    }

    .label-xs .label-text {
      font-size: 9.5px;
    }

    .label-sm .label-text {
      font-size: 10.5px;
    }

    .label-md .label-text {
      font-size: 11.5px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-hover-cell] {
      transition: none !important;
    }
  }
</style>
